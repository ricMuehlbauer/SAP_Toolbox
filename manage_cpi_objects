*       Controle dos botões:
*----------------------------------------------------------------------*
FORM zf_user_command USING l_ucomm    LIKE sy-ucomm
                           w_selfield TYPE slis_selfield.

  CASE l_ucomm.
    WHEN '&DETALHAR'.
      IF p_ico IS NOT INITIAL.
***********************************************
*        ICO
***********************************************
        READ TABLE t_saida_alv_ico INTO w_saida_alv_ico WITH KEY check = 'X'.
        IF sy-subrc EQ 0.
          FREE: t_saida_alv_detail_ico.
*         Buscar detalhes dos ICO's
          PERFORM zf_detalhar_ico USING w_saida_alv_ico.
          PERFORM zf_monta_alv USING 'X'.
        ENDIF.
      ELSE.
***********************************************
*       COMUNICATION CHANNEL
***********************************************
        READ TABLE t_saida_alv_cc INTO w_saida_alv_cc WITH KEY check = 'X'.
        IF sy-subrc EQ 0.
          FREE: t_saida_alv_detail_cc.
*         Buscar detalhes dos CC´s
          PERFORM zf_detalhar_cc USING w_saida_alv_cc.
          PERFORM zf_monta_alv USING 'X'.
        ENDIF.
      ENDIF."IF p_ico IS NOT INITIAL.
    WHEN OTHERS.
      IF p_ico IS NOT INITIAL.
***********************************************
*      ICO
***********************************************
        CASE w_selfield-fieldname.
          WHEN 'OUTRVICC_CHANNELID'.
            READ TABLE t_saida_alv_ico INTO w_saida_alv_ico INDEX w_selfield-tabindex.
            IF sy-subrc EQ 0 AND w_saida_alv_ico-outrvicc_channelid IS NOT INITIAL.
*             Chamada do CC do alv principal
              SUBMIT ZMANAGE_CPI_OBJECTS
                                                    WITH   p_paid EQ w_saida_alv_ico-outrvicc_partyid
                                                    WITH   p_coid EQ w_saida_alv_ico-outrvicc_componentid
                                                    WITH   p_chid EQ w_saida_alv_ico-outrvicc_channelid
                                                    WITH   p_pi   EQ p_pi
*                                                    WITH   p_grc  EQ p_grc
                                                    WITH   p_ico  EQ ' '
                                                    WITH   p_cco  EQ 'X'
                                                    WITH   p_detc EQ 'X'
                                                    AND RETURN.
            ELSE.
*             Chamada do CC direto da tela de detalhes do ICO
              READ TABLE t_saida_alv_detail_ico INTO w_saida_alv_ico INDEX w_selfield-tabindex.
              IF sy-subrc EQ 0 AND w_saida_alv_ico-outrvicc_channelid IS NOT INITIAL.
                SUBMIT ZMANAGE_CPI_OBJECTS
                                                      WITH   p_paid EQ w_saida_alv_ico-outrvicc_partyid
                                                      WITH   p_coid EQ w_saida_alv_ico-outrvicc_componentid
                                                      WITH   p_chid EQ w_saida_alv_ico-outrvicc_channelid
                                                      WITH   p_pi   EQ p_pi
*                                                      WITH   p_grc  EQ p_grc
                                                      WITH   p_ico  EQ ' '
                                                      WITH   p_cco  EQ 'X'
                                                      WITH   p_detc EQ 'X'
                                                      AND RETURN.

              ENDIF.
            ENDIF.
          WHEN 'CC_CHANNELID'.
            READ TABLE t_saida_alv_ico INTO w_saida_alv_ico INDEX w_selfield-tabindex.
            IF sy-subrc EQ 0 AND w_saida_alv_ico-outrvicc_channelid IS NOT INITIAL.
*             Chamada do CC do alv principal
              SUBMIT ZMANAGE_CPI_OBJECTS
                                                    WITH   p_paid EQ w_saida_alv_ico-cc_tyid
                                                    WITH   p_coid EQ w_saida_alv_ico-cc_componentid
                                                    WITH   p_chid EQ w_saida_alv_ico-cc_channelid
                                                    WITH   p_pi   EQ p_pi
*                                                    WITH   p_grc  EQ p_grc
                                                    WITH   p_ico  EQ ' '
                                                    WITH   p_cco  EQ 'X'
                                                    WITH   p_detc EQ 'X'
                                                    AND RETURN.
            ELSE.
*             Chamada do CC direto da tela de detalhes do ICO
              READ TABLE t_saida_alv_detail_ico INTO w_saida_alv_ico INDEX w_selfield-tabindex.
              IF sy-subrc EQ 0 AND w_saida_alv_ico-outrvicc_channelid IS NOT INITIAL.
                SUBMIT ZMANAGE_CPI_OBJECTS
                                                      WITH   p_paid EQ w_saida_alv_ico-cc_tyid
                                                      WITH   p_coid EQ w_saida_alv_ico-cc_componentid
                                                      WITH   p_chid EQ w_saida_alv_ico-cc_channelid
                                                      WITH   p_pi   EQ p_pi
*                                                      WITH   p_grc  EQ p_grc
                                                      WITH   p_ico  EQ ' '
                                                      WITH   p_cco  EQ 'X'
                                                      WITH   p_detc EQ 'X'
                                                      AND RETURN.

              ENDIF.
            ENDIF.
        ENDCASE.
      ENDIF.
  ENDCASE. " CASE l_ucomm.

ENDFORM.                    "zf_user_command

