                                  with key zparam = 'SRS_DETALHES'
                                           zvlpar = sy-uname.
    if sy-subrc eq 0.
      v_SRS_DETALHES = 'X'.
    endif.
    loop at t_fcatsrs ASSIGNING FIELD-SYMBOL(<f_fcat_srs>).
      case <f_fcat_srs>-fieldname.
