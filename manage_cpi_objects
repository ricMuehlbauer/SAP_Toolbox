                  EXPORTING
                    EDIT_MODE = ''
                  TABLES
                    t_txwnote = t_artifacts_deplo.
                free: t_artifacts_deplo.
              endif." if t_artifacts_deplo[] is NOT INITIAL.

            endif." if t_csv_data[] is NOT INITIAL.

          ENDIF."READ TABLE t_file IN

        ENDIF.

      else.
        MESSAGE e000(oo) WITH text-c13.
      endif."READ TABLE t_ztbbc_parametros

