        t_return    TYPE TABLE OF bapiret2,
        t_xml_table TYPE TABLE OF smum_xmltb,
        w_xml_table like LINE OF t_xml_table.

  if P_secuma ns '*' or p_copy eq 'X'.

    READ TABLE t_ztbbc_parametros TRANSPORTING NO FIELDS
                                  with key zparam = 'SRS_DETALHES'
                                           zvlpar = sy-uname.
    if sy-subrc eq 0.

      if P_MATERIAL_CREDENTIAL  is NOT INITIAL.
*       Relacionar SM59 configurada para ambiente BTP
        free: v_client.
        cl_http_client=>create_by_destination(
           EXPORTING destination = v_dest "SM59
           IMPORTING client      = v_client ).

*       Informar no Header o nome da interface a ser chamada
        CALL METHOD v_client->request->set_header_field
          EXPORTING
            name  = 'iflowname'
            value = 'IF_VSA_Artifacts_Get_Cred_Pas'.

        l_cred = P_MATERIAL_CREDENTIAL.
        CALL METHOD v_client->request->set_header_field
          EXPORTING
            name  = 'Credential_Name'
            value = l_cred.

        if P_secuma cs '*'.
          l_cred = 'NO'.
        else.
          l_cred = sy-uname.
        endif.
        if p_copy = 'X'.
          l_cred = sy-uname.
        endif.

        CALL METHOD v_client->request->set_header_field
          EXPORTING
            name  = 'uname'
            value = l_cred.

        v_client->request->set_method(  if_http_request=>co_request_method_post ).
        v_client->request->set_content_type( v_content_type ).
*       Chamada do Iflow
        v_client->send( ).
*       Retorno do Iflow
        v_client->receive( ).
*       Status do Iflow
        v_client->response->get_status( IMPORTING
                                          code   = l_http_rc
                                          reason = l_reason ).
*       Leitura do response
        l_response = v_client->response->get_cdata( ).
        free: v_client.

        if l_http_rc = 200.

*         XML para tabela interna
          CALL FUNCTION 'SCMS_STRING_TO_XSTRING'
            EXPORTING
              text   = l_response
            IMPORTING
              buffer = l_xstring
            EXCEPTIONS
              failed = 1
              OTHERS = 2.

          CALL FUNCTION 'SMUM_XML_PARSE'
            EXPORTING
              xml_input = l_xstring
            TABLES
              xml_table = t_xml_table
              return    = t_return.

          READ TABLE t_xml_table WITH KEY cname = 'Password' into w_xml_table.
          if sy-subrc eq 0.
            P_MATERIAL_PASS                = w_xml_table-cvalue.
          else.
            READ TABLE t_xml_table WITH KEY cname = 'PASSWORD' into w_xml_table.
            if sy-subrc eq 0.
              P_MATERIAL_PASS                = w_xml_table-cvalue.
            endif.
          endif.

        endif."if l_http_rc = 200.

      endif.
    endif.
  endif.


ENDFORM.   "get_service_mate_pass

