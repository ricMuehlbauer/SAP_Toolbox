*&---------------------------------------------------------------------*
*&     Form zf_get_buscar_resources
*&---------------------------------------------------------------------*
FORM zf_get_buscar_resources.
  data: l_http_rc       type sy-subrc,
        l_reason        type String,
        l_response      TYPE string,
        l_xstring       TYPE xstring,
        t_return        TYPE TABLE OF bapiret2,
        t_xml_table     TYPE TABLE OF smum_xmltb,
        t_artifacts_tmp TYPE TABLE OF y_artifacts,
        l_msg_progress  TYPE char100,
        l_percentage(3) TYPE n.

  IF p_cpire IS NOT INITIAL.

    free: t_artifacts_tmp.
    describe TABLE t_artifacts LINES data(l_total).

    loop at t_artifacts INTO w_artifacts.

      data(l_tabix_t_artifacts) = sy-tabix.

      concatenate text-c06 w_artifacts-name_art into l_msg_progress SEPARATED BY space.
      l_percentage = ( sy-tabix / l_total ) * 100.
      CALL FUNCTION 'SAPGUI_PROGRESS_INDICATOR'
        EXPORTING
          percentage = l_percentage
          text       = l_msg_progress.

****************************
* Busca Artifacts do pacote
****************************
*     Relacionar SM59 configurada para ambiente BTP
      free: v_client.
      cl_http_client=>create_by_destination(
         EXPORTING destination = v_dest "SM59
         IMPORTING client      = v_client ).

*     Informar no Header o nome da interface a ser chamada
      CALL METHOD v_client->request->set_header_field
        EXPORTING
          name  = 'iflowname'
          value = 'IF_VSA_Artifacts_Get_ArtifactsResources'.

      CALL METHOD v_client->request->set_header_field
        EXPORTING
          name  = 'id'
          value = w_artifacts-id_art.

      CALL METHOD v_client->request->set_header_field
        EXPORTING
          name  = 'version'
          value = W_ARTIFACTS-version_ART.

      v_client->request->set_method(  if_http_request=>co_request_method_post ).
      v_client->request->set_content_type( v_content_type ).

*     Chamada do Iflow
      v_client->send( ).
*     Retorno do Iflow
      v_client->receive( ).
*     Status do Iflow
      v_client->response->get_status( IMPORTING
                                        code   = l_http_rc
                                        reason = l_reason ).
*     Leitura do response
      l_response = v_client->response->get_cdata( ).
      free: v_client.

      if l_http_rc = 200.

*       XML para tabela interna
        CALL FUNCTION 'SCMS_STRING_TO_XSTRING'
          EXPORTING
            text   = l_response
          IMPORTING
            buffer = l_xstring
          EXCEPTIONS
            failed = 1
            OTHERS = 2.

        CALL FUNCTION 'SMUM_XML_PARSE'
          EXPORTING
            xml_input = l_xstring
          TABLES
            xml_table = t_xml_table
            return    = t_return.

        do.
*         Procura a tag Properties
          READ TABLE t_xml_table WITH KEY cname = 'properties' TRANSPORTING NO FIELDS.
          if sy-subrc ne 0.
*           Todos os pacotes lidos, sair do loop.
            exit.
          else.
            data(l_indice) = sy-tabix.
            data(l_indice_limpeza) = 1.
            do.
*             Elimina registros anteriores ao properties.
              delete t_xml_table index 1.
              l_indice_limpeza = l_indice_limpeza + 1.
              if l_indice_limpeza = l_indice.
*               Chegou no 'properties'
                delete t_xml_table INDEX 1."deleta 'properties'
                exit.
              endif.
            enddo.
          endif.


          READ TABLE t_xml_table TRANSPORTING NO FIELDS with key cname = 'Name'.
          if sy-subrc eq 0.
*           Nome do Artifact
            IF line_exists( t_xml_table[ cname = 'Name' ] ).
              w_artifacts-name_res               = t_xml_table[ cname = 'Name' ]-cvalue.
            endif.
*           Versão do Artifact
            IF line_exists( t_xml_table[ cname = 'ResourceType' ] ).
              w_artifacts-type_res             = t_xml_table[ cname = 'ResourceType' ]-cvalue.
            endif.

            APPEND w_artifacts to t_artifacts_tmp.

          endif."READ TABLE t_xml_table TRANSPORTING NO FIELDS with key cname = 'Id'. PACKAGE

        enddo.

      endif."if l_http_rc = 200. "IF_VSA_Artifacts_Get_ArtifactsPackages

    endloop."at t_artifacts INTO w_artifacts.

    t_artifacts[] = t_artifacts_tmp[].

    free: t_artifacts_tmp.

  ENDIF."  IF p_cpire IS NOT INITIAL.

ENDFORM.   "zf_get_buscar_resources


