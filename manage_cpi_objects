        t_return      TYPE TABLE OF bapiret2,
        t_xml_table   TYPE TABLE OF smum_xmltb,
        w_xml_table   like LINE OF t_xml_table.

* Relacionar SM59 configurada para ambiente BTP
  free: v_client.
  cl_http_client=>create_by_destination(
     EXPORTING destination = v_dest "SM59
     IMPORTING client      = v_client ).

* Informar no Header o nome da interface a ser chamada
  CALL METHOD v_client->request->set_header_field
    EXPORTING
      name  = 'iflowname'
      value = 'IF_VSA_MANAGEMENT_Get_Destinations'.

  if sy-host cs '05c' or sy-host cs '05a' or sy-host cs 'vide05'.
*   Informar no Header o nome da interface a ser chamada
    CALL METHOD v_client->request->set_header_field
      EXPORTING
        name  = 'ambiente'
        value = 'CORPPRD'.
  else.
*   Informar no Header o nome da interface a ser chamada
    CALL METHOD v_client->request->set_header_field
      EXPORTING
        name  = 'ambiente'
        value = 'CORPDEV'.
  endif.

  v_client->request->set_method(  if_http_request=>co_request_method_post ).
  v_client->request->set_content_type( v_content_type ).
* Chamada do Iflow
  v_client->send( ).
* Retorno do Iflow
  v_client->receive( ).
* Status do Iflow
  v_client->response->get_status( IMPORTING
                                    code   = l_http_rc
                                    reason = l_reason ).
* Leitura do response
  l_response = v_client->response->get_cdata( ).
  free: v_client, t_apim.

  if l_http_rc = 200.

    free: t_dest.

    DATA: w_ixml                        TYPE REF TO if_ixml,
          w_document                    TYPE REF TO if_ixml_document,
          w_stream_fact                 TYPE REF TO if_ixml_stream_factory,
          w_istream                     TYPE REF TO if_ixml_istream,
          w_parser                      TYPE REF TO if_ixml_parser,
          w_root                        TYPE REF TO if_ixml_element,
          w_node_list                   TYPE REF TO if_ixml_node_list,
          w_iter                        TYPE REF TO if_ixml_node_iterator,
          w_node                        TYPE REF TO if_ixml_node,
          w_child_iter                  TYPE REF TO if_ixml_node_iterator,
          w_child_node                  TYPE REF TO if_ixml_node,
          l_name                        TYPE string,
          l_value                       TYPE string,
          l_destname                    TYPE string,
          l_user                        TYPE string,
          l_Type                        type string,
          l_URL                         type string,
          l_Authentication              type string,
          l_ProxyType                   type string,
          l_Password                    type string,
          l_tokenServiceUser            type string,
          l_clientSecret                type string,
          l_tokenServiceURL             type string,
          l_tokenServicePassword        type string,
          l_jco_client_sysnr            type string,
          l_jco_destination_proxy_type  type string,
          l_jco_client_hcc_location_id  type string,
          l_jco_client_lang             type string,
          l_jco_client_passwd           type string,
          l_jco_destination_auth_type   type string,
          l_jco_client_client           type string,
          l_jco_client_user             type string,
          l_jco_client_mshost           type string,
          l_jco_client_msserv           type string,
          l_jco_destination_repo_user   type string,
          l_jco_destination_repo_passwd type string,
          l_jco_client_ashost           type string,
          l_mail_smtp_port              type string,
          l_mail_description            type string,
          l_mail_user                   type string,
          l_mail_smtp_host              type string,
          l_HTML5_DynamicDestination    type string,
          l_HTML5_Timeout               type string,
          l_WebIDEEnabled               type string,
          l_sap_client                  type string,
          l_WebIDEUsage                 type string,
          L_DESCRIPTION                 type string,
          L_checkconnec                 type string,
          l_traCE                       type string,
          L_DELTA                       type string,
          L_SERIAFOR                    type string,
          L_CLINET                      type string,
          w_dest                        like line of t_dest.

    " iXML
    w_ixml = cl_ixml=>create( ).
    w_stream_fact = w_ixml->create_stream_factory( ).
    w_istream = w_stream_fact->create_istream_string( l_response ).
    w_document = w_ixml->create_document( ).
    w_parser = w_ixml->create_parser( stream_factory = w_stream_fact
                                      istream = w_istream
                                      document = w_document ).

    IF w_parser->parse( ) <> 0.
      MESSAGE 'Erro parse XML' TYPE 'E'.
      RETURN.
    ENDIF.

    " Root → lista Destinations
    w_root = w_document->get_root_element( ).
    w_node_list = w_root->get_children( ).
    w_iter = w_node_list->create_iterator( ).
    w_node = w_iter->get_next( ).

    WHILE w_node IS NOT INITIAL.
      CLEAR: l_name, l_user, l_password, l_Type, l_URL, l_Authentication, l_ProxyType,
             l_User, l_Password, l_tokenServiceUser, l_clientSecret, l_tokenServiceURL,
             l_tokenServicePassword, l_jco_client_sysnr, l_jco_destination_proxy_type,
             l_jco_client_hcc_location_id, l_jco_client_lang, l_jco_client_passwd,
             l_jco_destination_auth_type, l_jco_client_client, l_jco_client_user,
             l_jco_client_mshost, l_jco_client_msserv, l_jco_destination_repo_user,
             l_jco_destination_repo_passwd, l_jco_client_ashost, l_mail_smtp_port,
             l_mail_description, l_mail_user, l_mail_smtp_host, l_HTML5_DynamicDestination,
             l_HTML5_Timeout, l_WebIDEEnabled, l_sap_client, l_WebIDEUsage.

      " Filhos de cada dest
      w_child_iter = w_node->create_iterator( ).
      w_child_node = w_child_iter->get_next( ).
      WHILE w_child_node IS NOT INITIAL.
        l_name = w_child_node->get_name( ).
        l_value = w_child_node->get_value( ).

        TRANSLATE l_name to UPPER CASE.

        CASE l_name.
          WHEN 'NAME'.
            l_destname = l_value.
          WHEN 'USER'.
            l_user = l_value.
          WHEN 'PASSWORD'.
            l_password = l_value.
          WHEN 'TYPE'.
            l_type = l_value.
          WHEN 'URL'.
            l_url = l_value.
          WHEN 'AUTHENTICATION'.
            l_authentication = l_value.
          WHEN 'PROXYTYPE'.
            l_proxytype = l_value.
          WHEN 'TOKENSERVICEUSER'.
            l_tokenserviceuser = l_value.
          WHEN 'CLIENTSECRET'.
            l_clientsecret = l_value.
          WHEN 'TOKENSERVICEURL'.
            l_tokenserviceurl = l_value.
          WHEN 'TOKENSERVICEPASSWORD'.
            l_tokenservicepassword = l_value.
          WHEN 'JCO.CLIENT.SYSNR' or 'JCO_CLIENT_SYSNR'.
            l_jco_client_sysnr = l_value.
          WHEN 'JCO.DESTINATION.PROXY_TYPE' or 'JCO_DESTINATION_PROXY_TYPE'.
            l_jco_destination_proxy_type = l_value.
          WHEN 'JCO.CLIENT.CLOUD_CONNECTOR_LOCATION_ID' or 'JCO_CLIENT_CLOUDCONNECTOR_LOCATION_ID'.
            l_jco_client_hcc_location_id = l_value.
          WHEN 'JCO.CLIENT.LANG' or 'JCO_CLIENT_LANG'.
            l_jco_client_lang = l_value.
          WHEN 'JCO.CLIENT.PASSWD' or 'JCO_CLIENT_PASSWD'.
            l_password = l_jco_client_passwd = l_value.
          WHEN 'JCO.DESTINATION.AUTH_TYPE' or 'JCO_DESTINATION_AUTH_TYPE'.
            l_jco_destination_auth_type = l_value.
          WHEN 'JCO.CLIENT.CLIENT' or 'JCO_CLIENT_CLIENT'.
            l_jco_client_client = l_value.
          WHEN 'JCO.CLIENT.USER' or 'JCO_CLIENT_USER'.
            l_user = l_jco_client_user = l_value.
          WHEN 'JCO.CLIENT.MSHOST' or 'JCO.CLIENT_MSHOST'.
            l_jco_client_mshost = l_value.
          WHEN 'JCO.CLIENT.MSSERV' or 'JCO_CLIENT_MSSERV'.
            l_jco_client_msserv = l_value.
          WHEN 'JCO.DESTINATION.REPOSITORY.USER' OR 'JCO_DESTINATION_REPOSITORY_USER'.
            l_jco_destination_repo_user = l_value.
          WHEN 'JCO.DESTINATION.REPOSITORY.PASSWD' OR 'JCO_DESTINATION_REPOSITORY_PASSWD'.
            l_jco_destination_repo_passwd = l_value.
          WHEN 'JCO.CLIENT.ASHOST' OR 'JCO_CLIENT_ASHOST'.
            l_jco_client_ashost = l_value.
          WHEN 'JCO_DESTINATION_DESCRIPTION' or 'JCO.DESTINATION.DESCRIPTION'.
            L_DESCRIPTION = l_value.
          WHEN 'JCO_DESTINATION_POOL_CHECK_CONNECTION' or 'JCO.DESTINATION.POOL_CHECK_CONNECTION'.
            L_checkconnec = l_value.
          WHEN 'JCO_CLIENT_TRACE' or 'JCO.CLIENT.TRACE'.
            l_traCE = l_value.
          WHEN 'JCO_CLIENT_DELTA' or 'JCO.CLIENT.DELTA'.
            L_DELTA = l_value.
          WHEN 'JCO_CLIENT_SERIALIZATION_FORMAT' or 'JCO.CLIENT.SERIALIZATION_FORMAT'.
            L_SERIAFOR = l_value.
          WHEN 'JCO_CLIENT_NETWORK' or 'JCO.CLIENT.NETWORK'.
            L_CLINET   = l_value.
          WHEN 'MAIL.SMTP.PORT'.
            l_mail_smtp_port = l_value.
          WHEN 'MAIL.DESCRIPTION'.
            l_mail_description = l_value.
          WHEN 'MAIL.USER'.
            l_user = l_mail_user = l_value.
          WHEN 'MAIL.SMTP.HOST'.
            l_mail_smtp_host = l_value.
          WHEN 'HTML5.DYNAMICDESTINATION'.
            l_html5_dynamicdestination = l_value.
          WHEN 'HTML5.TIMEOUT'.
            l_html5_timeout = l_value.
          WHEN 'WEBIDEENABLED'.
            l_webideenabled = l_value.
          WHEN 'SAP.CLIENT'.
            l_sap_client = l_value.
          WHEN 'WEBIDEUSAGE'.
            l_webideusage = l_value.
        ENDCASE.

        w_child_node = w_child_iter->get_next( ).
      ENDWHILE.

      " Preenche t_dest
      IF l_destname IS NOT INITIAL.
        CLEAR w_dest.
        w_dest-name                         = l_destname.
        w_dest-type                         = l_type.
        w_dest-url                          = l_url.
        w_dest-authentication               = l_authentication.
        w_dest-proxytype                    = l_proxytype.
        w_dest-user                         = l_user.
        w_dest-password                     = l_password.
        w_dest-tokenserviceuser             = l_tokenserviceuser.
        w_dest-clientsecret                 = l_clientsecret.
        w_dest-tokenserviceurl              = l_tokenserviceurl.
        w_dest-tokenservicepassword         = l_tokenservicepassword.
        w_dest-jco_client_sysnr             = l_jco_client_sysnr.
        w_dest-jco_destination_proxy_type   = l_jco_destination_proxy_type.
        w_dest-jco_client_hcc_location_id   = l_jco_client_hcc_location_id.
        w_dest-jco_client_lang              = l_jco_client_lang.
        w_dest-jco_client_passwd            = l_jco_client_passwd.
        w_dest-jco_destination_auth_type    = l_jco_destination_auth_type.
        w_dest-jco_client_client            = l_jco_client_client.
        w_dest-jco_client_user              = l_jco_client_user.
        w_dest-jco_client_mshost            = l_jco_client_mshost.
        w_dest-jco_client_msserv            = l_jco_client_msserv.
        w_dest-jco_destination_repo_user    = l_jco_destination_repo_user.
        w_dest-jco_destination_repo_passwd  = l_jco_destination_repo_passwd.
        w_dest-jco_client_ashost            = l_jco_client_ashost.
        w_dest-jco_destination_description  = L_DESCRIPTION.
        w_dest-jco_destination_check_connec = L_checkconnec.
        w_dest-jco_client_trace             = l_traCE.
        w_dest-jco_client_delta             = L_DELTA.
        w_dest-jco_client_seriali_format    = L_SERIAFOR.
        w_dest-jco_client_network           = L_CLINET.
        w_dest-mail_smtp_port               = l_mail_smtp_port.
        w_dest-mail_description             = l_mail_description.
        w_dest-mail_user                    = l_mail_user.
        w_dest-mail_smtp_host               = l_mail_smtp_host.
        w_dest-html5_dynamicdestination     = l_html5_dynamicdestination.
        w_dest-html5_timeout                = l_html5_timeout.
        w_dest-webideenabled                = l_webideenabled.
        w_dest-sap_client                   = l_sap_client.
        w_dest-webideusage                  = l_webideusage.

*       Filtro de dest
        if P_destna ns '*'.
          if w_dest-name ne P_destna.
            w_node = w_iter->get_next( ).
            continue.
          endif.
        endif.
        if P_destna cs '*'.
          if w_dest-name np P_destna.
            w_node = w_iter->get_next( ).
            continue.
          endif.
        endif.

*       Filtro de type
        if P_destty ns '*'.
          if w_dest-type ne P_destty.
            w_node = w_iter->get_next( ).
            continue.
          endif.
        endif.
        if P_destty cs '*'.
          if w_dest-type np P_destty.
            w_node = w_iter->get_next( ).
            continue.
          endif.
        endif.

*       Filtro de usuario
        if P_destus ns '*'.
          if w_dest-user ne P_destus.
            w_node = w_iter->get_next( ).
            continue.
          endif.
        endif.
        if P_destus cs '*'.
          if w_dest-user np P_destus.
            w_node = w_iter->get_next( ).
            continue.
          endif.
        endif.

        APPEND w_dest TO t_dest.
      ENDIF.
      w_node = w_iter->get_next( ).
    ENDWHILE.

  endif."if l_http_rc = 200.

  if t_dest[] is INITIAL.
*   Sem dados para seleção.
    MESSAGE s000(oo) WITH TEXT-C01 DISPLAY LIKE 'E'.
  endif.

ENDFORM.   "zf_get_dest


*&---------------------------------------------------------------------*
*&     Form zf_get_service_keys
*&---------------------------------------------------------------------*
FORM zf_get_service_keys.
  data: l_http_rc   type sy-subrc,
        l_reason    type String,
        l_response  TYPE string,
        l_xstring   TYPE xstring,
        t_return    TYPE TABLE OF bapiret2,
        t_xml_table TYPE TABLE OF smum_xmltb,
        w_xml_table like LINE OF t_xml_table.

* Relacionar SM59 configurada para ambiente BTP
  free: v_client.
  cl_http_client=>create_by_destination(
     EXPORTING destination = v_dest "SM59
     IMPORTING client      = v_client ).

* Informar no Header o nome da interface a ser chamada
  CALL METHOD v_client->request->set_header_field
    EXPORTING
      name  = 'iflowname'
      value = 'IF_VSA_Get_Service_Key_All'.

  if sy-host cs '05c' or sy-host cs '05a' or sy-host cs 'vide05'.
    v_instance = P_INSTAP.
  else.
    v_instance = P_INSTAD.
  endif.

  CALL METHOD v_client->request->set_header_field
    EXPORTING
      name  = 'instanceguid'
      value = v_instance.

  v_client->request->set_method(  if_http_request=>co_request_method_post ).
  v_client->request->set_content_type( v_content_type ).
* Chamada do Iflow
  v_client->send( ).
* Retorno do Iflow
  v_client->receive( ).
* Status do Iflow
  v_client->response->get_status( IMPORTING
                                    code   = l_http_rc
                                    reason = l_reason ).
* Leitura do response
  l_response = v_client->response->get_cdata( ).
  free: v_client.

  if l_http_rc = 200.

*   XML para tabela interna
    CALL FUNCTION 'SCMS_STRING_TO_XSTRING'
      EXPORTING
        text   = l_response
      IMPORTING
        buffer = l_xstring
      EXCEPTIONS
        failed = 1
        OTHERS = 2.

    CALL FUNCTION 'SMUM_XML_PARSE'
      EXPORTING
        xml_input = l_xstring
      TABLES
        xml_table = t_xml_table
        return    = t_return.

    free: t_service_keys.

    do.
*     Procura a tag Properties
      READ TABLE t_xml_table WITH KEY cname = 'guid' hier = 3 TRANSPORTING NO FIELDS.
      if sy-subrc ne 0.
*       Todos os pacotes lidos, sair do loop.
        exit.
      else.
        data(l_indice) = sy-tabix.
        data(l_indice_limpeza) = 1.
        do.
*         Elimina registros anteriores ao properties.
          delete t_xml_table index 1.
          l_indice_limpeza = l_indice_limpeza + 1.
          if l_indice_limpeza = l_indice.
*           Chegou no 'guid'
            clear w_service_keys.
            w_service_keys-guid = t_xml_table[ cname = 'guid' ]-cvalue.
            delete t_xml_table INDEX 1."deleta 'guid'
            exit.
          endif.
        enddo.

        READ TABLE t_xml_table WITH KEY cname = 'created_at' into w_xml_table.
        if sy-subrc eq 0.
          CONCATENATE w_xml_table-cvalue+0(4) w_xml_table-cvalue+5(2)
                      w_xml_table-cvalue+8(2) into w_service_keys-created_at."2024-01-18T00:18:11-03:00
          CONCATENATE w_xml_table-cvalue+0(4) w_xml_table-cvalue+5(2)
                      w_xml_table-cvalue+8(2) into w_service_keys-updated_at."2024-01-18T00:18:11-03:00
          w_service_keys-name                 = t_xml_table[ cname = 'name' ]-cvalue.
          w_service_keys-type                 = t_xml_table[ cname = 'type' ]-cvalue.
          w_service_keys-state                = t_xml_table[ cname = 'state' ]-cvalue.
          w_service_keys-json                 = '@TD@'.
          append w_service_keys to t_service_keys.
        else.
          exit.
        endif.

      endif.
    enddo.

*   Filtro de Package
    if P_srname ns '*'.
      delete t_service_keys WHERE name ne P_srname.
    endif.
    if P_srname cs '*'.
      delete t_service_keys WHERE name np P_srname.
    endif.

  endif."if l_http_rc = 200.

  if t_service_keys[] is INITIAL.
*   Sem dados para seleção.
    MESSAGE s000(oo) WITH TEXT-C01 DISPLAY LIKE 'E'.
*    stop.
  endif.

ENDFORM.   "zf_get_service_keys

*&---------------------------------------------------------------------*
*&     Form zf_get_service_keys_det
*&---------------------------------------------------------------------*
FORM zf_get_service_keys_det .
  data: l_http_rc   type sy-subrc,
        l_reason    type String,
        l_response  TYPE string,
        l_xstring   TYPE xstring,
        t_return    TYPE TABLE OF bapiret2,
        t_xml_table TYPE TABLE OF smum_xmltb,
        w_xml_table like line OF t_xml_table,
        l_nameguid  type string,
        l_fuso      type INT4,
        l_data      type sy-datum.

  if p_detser is NOT INITIAL.
    loop at t_service_keys into w_service_keys.
      data(l_tabix) = sy-tabix.

      clear: l_response, l_http_rc, l_reason, l_xstring.
      message s000(oo) with text-075 w_service_keys-name DISPLAY LIKE 'S'.

*   Relacionar SM59 configurada para ambiente BTP
      free: v_client.
      cl_http_client=>create_by_destination(
         EXPORTING destination = v_dest "SM59
         IMPORTING client      = v_client ).

*   Informar no Header o nome da interface a ser chamada
      CALL METHOD v_client->request->set_header_field
        EXPORTING
          name  = 'iflowname'
          value = 'IF_VSA_Get_Service_Key_Detail'.

      l_nameguid = w_service_keys-guid.
      CALL METHOD v_client->request->set_header_field
        EXPORTING
          name  = 'nameguid'
          value = l_nameguid.

      v_client->request->set_method(  if_http_request=>co_request_method_post ).
      v_client->request->set_content_type( v_content_type ).
*     Chamada do Iflow
      v_client->send( ).
*     Retorno do Iflow
      v_client->receive( ).
*     Status do Iflow
      v_client->response->get_status( IMPORTING
                                        code   = l_http_rc
                                        reason = l_reason ).
*     Leitura do response
      l_response = v_client->response->get_cdata( ).
      free: v_client.

      if w_service_keys-state = 'failed'.
        w_service_keys-icon = '@0A@'."'ICON_RED_LIGHT'.
      endif.

      if l_http_rc = 200.

*       XML para tabela interna
        CALL FUNCTION 'SCMS_STRING_TO_XSTRING'
          EXPORTING
            text   = l_response
          IMPORTING
            buffer = l_xstring
          EXCEPTIONS
            failed = 1
            OTHERS = 2.

        free: t_xml_table.
        CALL FUNCTION 'SMUM_XML_PARSE'
          EXPORTING
            xml_input = l_xstring
          TABLES
            xml_table = t_xml_table
            return    = t_return.

        READ TABLE t_xml_table WITH KEY cname = 'issuerdn' into w_xml_table.
        if sy-subrc eq 0.
          w_service_keys-issuerdn             = w_xml_table-cvalue.
        endif.

        READ TABLE t_xml_table WITH KEY cname = 'subjectdn' into w_xml_table.
        if sy-subrc eq 0.
          w_service_keys-subjectdn            = w_xml_table-cvalue.
        endif.

        READ TABLE t_xml_table WITH KEY cname = 'validuntil' into w_xml_table.
        if sy-subrc eq 0.
          CONCATENATE w_xml_table-cvalue+0(4) w_xml_table-cvalue+5(2)
                      w_xml_table-cvalue+8(2) into w_service_keys-validuntil."2024-01-18T00:18:11-03:00
          CONCATENATE w_xml_table-cvalue+11(2) w_xml_table-cvalue+14(2)
                      w_xml_table-cvalue+17(2) into w_service_keys-timeuntil."2024-01-18T00:18:11-03:00

          l_fuso = w_xml_table-cvalue+21(1).
          CALL FUNCTION 'IGN_TIMESTAMP_PLUSMINUS'
            EXPORTING
              START_DATE      = w_service_keys-validuntil
              START_TIME      = w_service_keys-timeuntil
              FORWARD         = ''
              BACKWARD        = 'X'
              HOURS           = l_fuso
            IMPORTING
              RESULT_DATE     = w_service_keys-validuntil
              RESULT_TIME     = w_service_keys-timeuntil
            EXCEPTIONS
              PARAMETER_ERROR = 1
              OTHERS          = 2.

        else.
          w_service_keys-validuntil = '99991231'.
          w_service_keys-timeuntil = '235959'.
        endif.

        READ TABLE t_xml_table WITH KEY cname = 'tokenurl' into w_xml_table.
        if sy-subrc eq 0.
          w_service_keys-tokenurl             = w_xml_table-cvalue.
        endif.

        READ TABLE t_xml_table WITH KEY cname = 'key' into w_xml_table.
        if sy-subrc eq 0.
          w_service_keys-key                  = w_xml_table-cvalue.
        endif.

        READ TABLE t_xml_table WITH KEY cname = 'certificate' into w_xml_table.
        if sy-subrc eq 0.
          w_service_keys-certificate          = w_xml_table-cvalue.
        else.
          READ TABLE t_xml_table WITH KEY cname = 'clientid' into w_xml_table.
          if sy-subrc eq 0.
            w_service_keys-clientid             = w_xml_table-cvalue.
          endif.
          READ TABLE t_xml_table WITH KEY cname = 'clientsecret' into w_xml_table.
          if sy-subrc eq 0.
            w_service_keys-clientsecret         = w_xml_table-cvalue.
          endif.
        endif.

        READ TABLE t_xml_table WITH KEY cname = 'url' into w_xml_table.
        if sy-subrc eq 0.
          w_service_keys-url                  = w_xml_table-cvalue.
        endif.

        if w_service_keys-validuntil = '99991231'.
*         Sem data de Vencimento
          w_service_keys-icon = '@08@'."'ICON_GREEN_LIGHT'.
        else.
          if sy-datum >= w_service_keys-validuntil.
*         Vencido
            w_service_keys-icon = '@0A@'."'ICON_RED_LIGHT'.
          else.
            w_service_keys-icon = '@08@'."'ICON_GREEN_LIGHT'.
            l_data = sy-datum - 15.
            if w_service_keys-validuntil >= l_data and
