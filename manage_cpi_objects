FORM zf_get_buscar_artefatos_run.
  data: l_http_rc       type sy-subrc,
        l_reason        type String,
        l_response      TYPE string,
        l_xstring       TYPE xstring,
        t_return        TYPE TABLE OF bapiret2,
        t_xml_table     TYPE TABLE OF smum_xmltb,
        t_artifacts_tmp TYPE TABLE OF y_artifacts,
        l_msg_progress  TYPE char100,
        l_percentage(3) TYPE n.

  CONSTANTS: c_stopping type char08 value 'stopping',
             c_starting type char08 value 'starting',
             c_error    type char05 value 'error'.

****************************
* Busca Artifacts Runtime
****************************
  if p_verru is NOT INITIAL.

    describe TABLE t_artifacts LINES data(l_total2).

    loop at t_artifacts INTO w_artifacts.

      data(l_tabix_t_artifacts2) = sy-tabix.

