                CALL METHOD v_editor->set_readonly_mode
                  EXPORTING
                    readonly_mode          = cl_gui_textedit=>true
                  EXCEPTIONS
                    error_cntl_call_method = 1
                    invalid_parameter      = 2.
              endif.
*              CALL METHOD v_editor->free.
*              free: v_EDITOR, v_container_text.
              set SCREEN 0.
              LEAVE SCREEN.
            else.
              MESSAGE s000(oo) with text-086 DISPLAY LIKE 'E'.
              clear: V_OKCODE, l_erro_tela.
            endif.
          endif.
        endif.
      else.
        MESSAGE W000(oo) with text-082 text-083.
