  case V_OKCODE.
    when 'BTN_CRIAR'.
      l_tamanho = strlen( W_SERVICE_KEY_NEW-name ).
      if l_tamanho > 3 and (
         W_SERVICE_KEY_NEW-name+0(3) = 'GL_'    or
         W_SERVICE_KEY_NEW-name+0(4) = 'CBA_'   or
         W_SERVICE_KEY_NEW-name+0(5) = 'VCBR_'  or
         W_SERVICE_KEY_NEW-name+0(5) = 'VCBO_'  or
