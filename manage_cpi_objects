    delete t_fcat where FieldNAME = 'CREATEDBY_PK'.
    delete t_fcat where FieldNAME = 'CREATIONDATE_PK'.
    delete t_fcat where FieldNAME = 'MODIFIEDBY_PK'.
    delete t_fcat where FieldNAME = 'MODIFIEDDATE_PK'.
    delete t_fcat where FieldNAME = 'ID_ART'.
    delete t_fcat where FieldNAME = 'CREATEDBY_ART'.
    delete t_fcat where FieldNAME = 'CREATEDAT_ART'.

    if p_verru is INITIAL.
      delete t_fcat where FieldNAME = 'TYPE_ART_RUN'.
      delete t_fcat where FieldNAME = 'DEPLOYEDBY_ART_RUN'.
      delete t_fcat where FieldNAME = 'DEPLOYEDON_ART_RUN'.
      delete t_fcat where FieldNAME = 'STATUS_ART_RUN'.
      delete t_fcat where FieldNAME = 'STATUS_ART_ICO_RUN'.
    endif.

    if p_cpire is INITIAL.
      delete t_fcat where FieldNAME = 'NAME_RES'.
      delete t_fcat where FieldNAME = 'TYPE_RES'.
    endif.

    if p_cpico is INITIAL.
      delete t_fcat where FieldNAME = 'PARAMETERKEY_CONF'.
      delete t_fcat where FieldNAME = 'PARAMETERVAL_CONF'.
      delete t_fcat where FieldNAME = 'UPDATED_CONF'.
      delete t_fcat where FieldNAME = 'USER_CONF'.
    endif.

    loop at t_fcat ASSIGNING FIELD-SYMBOL(<f_fcat_local>).
      case <f_fcat_local>-fieldname.
        when 'NAME_PK'.
          <f_fcat_local>-SCRTEXT_L = c_package.
        when 'NAME_ART'.
          <f_fcat_local>-SCRTEXT_L = c_artifact.
        when 'VERSION_ART'.
          <f_fcat_local>-SCRTEXT_L = c_version.
        when 'SENDER_ART'.
          <f_fcat_local>-SCRTEXT_L = c_sender.
        when 'RECEIVER_ART'.
          <f_fcat_local>-SCRTEXT_L = c_receiver.
        when 'MODIFIEDBY_ART'.
          <f_fcat_local>-SCRTEXT_L = C_Modifiedby.
        when 'MODIFIEDAT_ART'.
          <f_fcat_local>-SCRTEXT_L = C_Modifiedat.
        when 'TYPE_ART_RUN'.
          <f_fcat_local>-SCRTEXT_L = c_type.
        when 'DEPLOYEDBY_ART_RUN'.
          <f_fcat_local>-SCRTEXT_L = C_Deployedby.
        when 'DEPLOYEDON_ART_RUN'.
          <f_fcat_local>-SCRTEXT_L = C_Deployedon.
        when 'STATUS_ART_ICO_RUN'.
          <f_fcat_local>-icon = 'X'.
        when 'STATUS_ART_RUN'.
          <f_fcat_local>-SCRTEXT_L = c_status.
