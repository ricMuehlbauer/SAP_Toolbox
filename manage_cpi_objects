          DESCRIBE TABLE t_security_material LINES data(v_qtde_srs).
          if v_qtde_srs eq 1.
            <f_fcat_srs>-no_out = ''.
          else.
            <f_fcat_srs>-no_out = 'X'.
          endif.
        when 'STATUS'.
