        WHEN 'SENDERPARTYID'.
          w_fieldcat-seltext_m = w_fieldcat-seltext_s = w_fieldcat-seltext_l = TEXT-034.
          w_fieldcatalog-scrtext_m = w_fieldcatalog-scrtext_s = w_fieldcatalog-scrtext_l = w_fieldcat-seltext_m.
