*&---------------------------------------------------------------------*
FORM zf_change_ico  CHANGING p_w_saida_alv_ico STRUCTURE w_saida_alv_ico
                             p_l_message.

  DATA: l_inalterado  TYPE c VALUE '',
        l_inalterado2 TYPE c VALUE ''.


  CLEAR: w_output_ico_openedit, w_input_ico_openedit,
         w_output_ico_change, w_input_ico_change, v_message.
  free: t_header_openedit.

* Abrir para Edição - Cria ChangeList
  w_header_openedit-sender_party_id        = p_w_saida_alv_ico-senderpartyid.
  w_header_openedit-sender_component_id    = p_w_saida_alv_ico-sendercomponentid.
  w_header_openedit-interface_name         = p_w_saida_alv_ico-interfacename.
  w_header_openedit-interface_namespace    = p_w_saida_alv_ico-interfacenamespace.
  w_header_openedit-receiver_party_id      = p_w_saida_alv_ico-receiverpartyid.
  w_header_openedit-receiver_component_id  = p_w_saida_alv_ico-receivercomponentid.
  APPEND w_header_openedit TO t_header_openedit.
  w_output_ico_openedit-integrated_configuration_open-integrated_configuration_id = t_header_openedit[].

  CALL FUNCTION 'ZFBC_VSA_API_ICO_OPENEDIT'
    EXPORTING
      output  = w_output_ico_openedit
    IMPORTING
      input   = w_input_ico_openedit
      message = p_l_message.

  IF p_l_message IS INITIAL.
*   Alterar registro
    FIELD-SYMBOLS: <f_w_integration_open> TYPE zintegrated_configuration7501.
    DATA: w_change_integrated TYPE zrestricted_integrated_configu,
          t_change_integrated TYPE zrestricted_integrated_con_tab.

    w_output_ico_change-integrated_configuration750cha-change_list_id = w_input_ico_openedit-integrated_configuration750ope-change_list_id-change_list_id.

    LOOP AT w_input_ico_openedit-integrated_configuration750ope-integrated_configuration ASSIGNING <f_w_integration_open>.

      CLEAR: <f_w_integration_open>-administrative_data, l_inalterado, l_inalterado2.
      FREE: t_change_integrated.

      IF p_lggl IS NOT INITIAL."Ativar Global
        IF <f_w_integration_open>-logging-use_global NE 'X'."Esá ativado o específico
          <f_w_integration_open>-logging-use_global = abap_true. "Ativar Global
          p_w_saida_alv_ico-logging = abap_true.
        ELSE.
*         Sem alteração
          l_inalterado = 'X'.
        ENDIF.
      ELSE.
*       Ativar o específico
        IF <f_w_integration_open>-logging-use_global NE ''."Está ativado o específico
          <f_w_integration_open>-logging-use_global = abap_false.
          p_w_saida_alv_ico-logging = abap_false.
          l_inalterado = ''.
          IF p_llog1 IS NOT INITIAL AND
             p_llog2 IS NOT INITIAL AND
             p_llog3 IS NOT INITIAL.
            CONCATENATE 'BI=' p_llog1 ',MS=' p_llog2 ',AM=' p_llog3
                        INTO <f_w_integration_open>-logging-specific_configuration."BI=0,MS=6,AM=14
            p_w_saida_alv_ico-loggingspecific = <f_w_integration_open>-logging-specific_configuration.
            l_inalterado = ''.
          ELSE.
*           Faltou preencher, Sem alteração
          ENDIF.
        ELSE.
*         Sem alteração
          l_inalterado = 'X'.
        ENDIF.
      ENDIF.

      IF p_stgl IS NOT INITIAL.
        IF <f_w_integration_open>-staging-use_global NE 'X'."Esá ativado o específico
          <f_w_integration_open>-staging-use_global = 'X'.
          p_w_saida_alv_ico-staging = 'X'.
        ELSE.
*         Sem alteração
          l_inalterado2 = 'X'.
        ENDIF.
      ELSE.
*       Ativar o específico
        IF <f_w_integration_open>-staging-use_global NE ''."Está ativado o específico
          <f_w_integration_open>-staging-use_global = ''.
          p_w_saida_alv_ico-staging = ''.
          l_inalterado = ''.
          IF p_lstg1 IS NOT INITIAL AND
             p_lstg2 IS NOT INITIAL AND
             p_lstg3 IS NOT INITIAL AND
             p_lstg4 IS NOT INITIAL AND
             p_lstg5 IS NOT INITIAL.
            CONCATENATE 'BI=' p_lstg1 ',VI=' p_lstg2 ',MS=' p_lstg3 ',AM=' p_lstg4 ',VO=' p_lstg5
                        INTO <f_w_integration_open>-staging-specific_configuration.  "BI=0,VI=1,MS=3,AM=0,VO=0
            p_w_saida_alv_ico-stagingspecific = <f_w_integration_open>-staging-specific_configuration.
            l_inalterado2 = ''.
          ELSE.
*           Faltou preencher, Sem alteração
          ENDIF.
        ELSE.
*         Sem alteração
          l_inalterado2 = 'X'.
        ENDIF.
      ENDIF.
      MOVE-CORRESPONDING <f_w_integration_open> TO w_change_integrated.
      APPEND w_change_integrated TO t_change_integrated.
    ENDLOOP.

    IF l_inalterado  NE 'X' or
       l_inalterado2 NE 'X'.
*     Se foi necessário alterar
      w_output_ico_change-integrated_configuration750cha-integrated_configuration = t_change_integrated[].

      CALL FUNCTION 'ZFBC_VSA_API_ICO_CHANGE'
        EXPORTING
          output  = w_output_ico_change
        IMPORTING
          input   = w_input_ico_change
          message = p_l_message.

      IF p_l_message IS INITIAL.
        p_l_message = TEXT-072.
      ELSE.
        PERFORM zf_changelist_revert USING w_input_ico_openedit-integrated_configuration750ope-change_list_id-change_list_id.
      ENDIF.

    ELSE.
      p_l_message = TEXT-073.
      PERFORM zf_changelist_revert USING w_input_ico_openedit-integrated_configuration750ope-change_list_id-change_list_id.
    ENDIF.
  ELSE.
    PERFORM zf_changelist_revert USING w_input_ico_openedit-integrated_configuration750ope-change_list_id-change_list_id.
  ENDIF.

ENDFORM.

