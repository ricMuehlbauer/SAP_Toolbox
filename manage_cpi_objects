*&---------------------------------------------------------------------*
*&      Form  ZF_PROCESS_ADAPTER_ATTRIBUTES
*&---------------------------------------------------------------------*
FORM zf_process_adapter_attributes USING p_adapter_attr_name   TYPE string
                                         p_adapter_attr_value  TYPE string
                                   CHANGING p_w_saida_alv_cc STRUCTURE w_saida_alv_cc.
  CASE p_adapter_attr_name.
    WHEN 'URLPattern' OR 'ftp.sourceDir' OR 'serverhost' OR 'XMBWS.TargetURL'.
      p_w_saida_alv_cc-targeturl = p_adapter_attr_value.
    WHEN 'ftp.host'.
      p_w_saida_alv_cc-ftphost = p_adapter_attr_value.
    WHEN 'in.channel.endpoint'.
      IF p_adapter_attr_value NE '' AND p_adapter_attr_value NE '0'.
        CONCATENATE '/RESTAdapter/' p_adapter_attr_value INTO p_w_saida_alv_cc-targeturl.
      ENDIF.
    WHEN 'logonUser' OR 'userName' OR 'ftp.user'.
      p_w_saida_alv_cc-logonuser = p_adapter_attr_value.
    WHEN 'authenticationModeBasicAnon'.
      p_w_saida_alv_cc-authenticationmodebasicanon = p_adapter_attr_value.
    WHEN 'logonLanguage'.
      p_w_saida_alv_cc-logonlanguage = p_adapter_attr_value.
    WHEN 'logonClient'.
      p_w_saida_alv_cc-logonclient = p_adapter_attr_value.
    WHEN 'useCert'.
      p_w_saida_alv_cc-usecert = p_adapter_attr_value.
    WHEN 'certificateAlias' OR 'KeyStoreEntry'.
      p_w_saida_alv_cc-certificatealias = p_adapter_attr_value.
    WHEN 'keystoreView' OR 'KeyStoreView'.
      p_w_saida_alv_cc-keystoreview = p_adapter_attr_value.
    WHEN 'useProxy'.
      p_w_saida_alv_cc-useproxy = p_adapter_attr_value.
    WHEN 'XMBWS.ProxyHost'.
      p_w_saida_alv_cc-proxyhost = p_adapter_attr_value.
    WHEN 'XMBWS.ProxyPort'.
      p_w_saida_alv_cc-proxyport = p_adapter_attr_value.
    WHEN 'useProxyAuth'.
      p_w_saida_alv_cc-useproxyauth = p_adapter_attr_value.
    WHEN 'XMBWS.ProxyUser'.
      p_w_saida_alv_cc-proxyuser = p_adapter_attr_value.
    WHEN 'filePath'.
      p_w_saida_alv_cc-filePath = p_adapter_attr_value.
  ENDCASE.
ENDFORM.

