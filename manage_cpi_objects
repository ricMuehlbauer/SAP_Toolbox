            CALL METHOD v_editor->SELECT_LINES
              EXPORTING
                FROM_LINE              = 1
                TO_LINE                = 9999
              EXCEPTIONS
                ERROR_CNTL_CALL_METHOD = 1
                others                 = 2.

            CALL METHOD v_EDITOR->GET_SELECTED_TEXT_AS_R3TABLE
              IMPORTING
                TABLE    = t_texto_certificado
              EXCEPTIONS
                ERROR_DP = 1
                others   = 3.

            clear: W_SERVICE_KEY_NEW-EXTERNALCERTIFICATE.
            DESCRIBE TABLE t_texto_certificado LINES data(l_linha).
            if l_linha > 1.
              loop at t_texto_certificado REFERENCE INTO data(w_texto_certificado).
