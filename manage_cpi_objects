      EXPORTING
        i_bypassing_buffer = 'X'
        i_structure_name   = 'ZSTBC_API_PI_ICO'
      CHANGING
        ct_fieldcat        = t_fieldcatalog.

    LOOP AT t_fieldcatalog INTO w_fieldcatalog.
      CLEAR w_fieldcat.
      MOVE-CORRESPONDING w_fieldcatalog TO w_fieldcat.
      w_fieldcat-seltext_m     = w_fieldcatalog-scrtext_m = w_fieldcat-fieldname.
      w_fieldcat-seltext_s     = w_fieldcatalog-scrtext_s = w_fieldcat-fieldname.
      w_fieldcat-seltext_l     = w_fieldcatalog-scrtext_l = w_fieldcat-fieldname.
      w_fieldcat-tabname       = 'ZSTBC_API_PI_ICO'.
      w_fieldcat-ref_fieldname = w_fieldcat-fieldname.
      w_fieldcat-ref_tabname   = 'ZSTBC_API_PI_ICO'.
      IF w_fieldcat-fieldname = 'OUTRVICC_CHANNELID' OR w_fieldcat-fieldname = 'CC_CHANNELID'.
        w_fieldcat-hotspot = 'X'.
      ENDIF.

