*&---------------------------------------------------------------------*
FORM zf_handle_user_command  USING P_E_UCOMM.
  data: l_http_rc         type sy-subrc,
        l_reason          type String,
        l_response        TYPE string,
        l_http_code       TYPE string,
        l_xstring         TYPE xstring,
        l_index           TYPE sy-tabix,
        t_rows            TYPE lvc_t_roid,
        t_artifacts_deplo TYPE STANDARD TABLE OF txw_note,
        t_usercred_copy   TYPE STANDARD TABLE OF txw_note,
        t_usercred_modi   TYPE STANDARD TABLE OF txw_note,
        w_usercred_copy   TYPE txw_note,
        w_usercred_modi   TYPE txw_note,
        w_artifacts_deplo like line of t_artifacts_deplo,
        w_row             TYPE lvc_s_roid,
        l_resp_confim     TYPE c,
        t_SVAL            TYPE TABLE of SVAL,
        w_SVAL            like line of t_SVAL,
        l_returncode      type c,
        l_pass            type string,
        l_retirarsufixo   type c,
        l_sufixo          type DD93S-ATTRNAME,
        l_answer_copy     type c,
        l_answer_modi     type c.

  CONSTANTS: c_stopping type char08 value 'stopping',
             c_starting type char08 value 'starting',
             c_error    type char05 value 'error'.
  " Obter linhas selecionadas via clique no ALV

  if p_cpi is NOT INITIAL.
    CALL METHOD v_alv->get_selected_rows
      IMPORTING
        et_row_no = t_rows.
  endif.
  if p_srk is NOT INITIAL.
    CALL METHOD v_alvsrk->get_selected_rows
      IMPORTING
        et_row_no = t_rows.
  endif.
  if p_srs is NOT INITIAL.
    CALL METHOD v_alvsrs->get_selected_rows
      IMPORTING
        et_row_no = t_rows.
  endif.
  if p_kvm is NOT INITIAL.
    CALL METHOD v_alvkvm->get_selected_rows
      IMPORTING
        et_row_no = t_rows.
  endif.
  if p_des is NOT INITIAL.
    CALL METHOD v_alvdest->get_selected_rows
      IMPORTING
        et_row_no = t_rows.
  endif.


  case P_E_UCOMM.
**********************************************************************
* Deployment / Undeployment
**********************************************************************
    when 'UNDEPLO' or 'DEPLO'.
      READ TABLE t_ztbbc_parametros TRANSPORTING NO FIELDS
                                    with key zparam = 'ADM_DEPLOY'
                                             zvlpar = sy-uname.
      if sy-subrc eq 0.
        free: t_artifacts_deplo.

        if t_rows[] is INITIAL.
          MESSAGE i000(oo) with text-c09.
        endif.
        data(l_answer) = '2'.
        CALL FUNCTION 'POPUP_TO_CONFIRM'
          EXPORTING
            titlebar              = TEXT-067
            text_question         = TEXT-090
            text_button_1         = TEXT-069
            text_button_2         = TEXT-070
            display_cancel_button = ''
            default_button        = '2'
          IMPORTING
            answer                = l_answer
          EXCEPTIONS
            text_not_found        = 1
            OTHERS                = 2.

        IF l_answer <> '2'.

          LOOP AT t_rows INTO w_row.
            l_index = w_row-row_id.

            READ TABLE t_artifacts INTO w_artifacts INDEX l_index.
            IF sy-subrc = 0.
              data(l_indice_art) = sy-tabix.

*             Relacionar SM59 configurada para ambiente BTP
              free: v_client.
              cl_http_client=>create_by_destination(
                 EXPORTING destination = v_dest "SM59
                 IMPORTING client      = v_client ).

*             Informar no Header o nome da interface a ser chamada
              CALL METHOD v_client->request->set_header_field
                EXPORTING
                  name  = 'iflowname'
                  value = 'IF_VSA_Iflow_Deploy_Undeploy'.

              CALL METHOD v_client->request->set_header_field
                EXPORTING
                  name  = 'id'
                  value = w_artifacts-id_art.

              CALL METHOD v_client->request->set_header_field
                EXPORTING
                  name  = 'version'
                  value = W_ARTIFACTS-version_ART.

              if P_E_UCOMM = 'UNDEPLO'.
                CALL METHOD v_client->request->set_header_field
                  EXPORTING
                    name  = 'mode'
                    value = 'DOWN'.
              elseif P_E_UCOMM = 'DEPLO'.
                CALL METHOD v_client->request->set_header_field
                  EXPORTING
                    name  = 'mode'
                    value = 'UP'.
              endif.
              v_client->request->set_method(  if_http_request=>co_request_method_post ).
              v_client->request->set_content_type( v_content_type ).

*             Chamada do Iflow
              v_client->send( ).
*             Retorno do Iflow
              v_client->receive( ).
*             Status do Iflow
              v_client->response->get_status( IMPORTING
                                                code   = l_http_rc
                                                reason = l_reason ).
*             Leitura do response
              l_response = v_client->response->get_cdata( ).
              free: v_client.

              if l_http_rc = 200 or l_http_rc = 202.
                if P_E_UCOMM = 'UNDEPLO'.
                  W_ARTIFACTS-Status_art_run = c_stopping.
                else.
                  W_ARTIFACTS-Status_art_run = c_starting.
                endif.
              else.
                W_ARTIFACTS-Status_art_run   = c_error.
              ENDIF."if l_http_rc = 200.

              case w_artifacts-Status_art_run.
                when 'STARTED'.
                  w_artifacts-status_art_ico_run = '@08@'."'ICON_GREEN_LIGHT'.
                when '' or c_error.
                  w_artifacts-status_art_ico_run = '@0A@'."'ICON_RED_LIGHT'.
                when 'STOPPING' or 'STARTING'.
                  w_artifacts-status_art_ico_run = '@09@'."'ICON_YELLOW_LIGHT'.
              ENDCASE.

              modify T_ARTIFACTS from W_ARTIFACTS INDEX l_indice_art.

              CONCATENATE w_artifacts-id_art w_artifacts-version_art W_ARTIFACTS-Status_art_run
                          INTO w_artifacts_deplo-line SEPARATED BY ';'.
              append w_artifacts_deplo to t_artifacts_deplo.

            ENDIF."READ TABLE t_artifacts IN
          ENDLOOP."LOOP AT t_rows INTO w_row.

          v_alv->refresh_table_display( ).
          if P_E_UCOMM = 'UNDEPLO'.
            MESSAGE s000(oo) WITH TEXT-c16.
          else.
            MESSAGE s000(oo) WITH TEXT-c15.
          endif.

          if t_artifacts_deplo[] is NOT INITIAL.
*           Exibir artefatos alterados
            CALL FUNCTION 'TXW_TEXTNOTE_EDIT'
              EXPORTING
                EDIT_MODE = ''
              TABLES
                t_txwnote = t_artifacts_deplo.
            free: t_artifacts_deplo.
          endif.
        ENDIF."IF l_answer <> '2'.

      else.
        MESSAGE e000(oo) WITH text-c13.
      ENDIF."READ TABLE t_ztbbc_parametros

**********************************************************************
* Deployment com arquivo CSV
**********************************************************************
    when 'DEPLOFILE'.
      TYPES: BEGIN OF y_csv_line,
               id      TYPE string,
               version TYPE string,
               status  TYPE string,
             END OF y_csv_line.

      data: l_file         type string,
            t_csv_data_raw TYPE STANDARD TABLE OF string,
            t_csv_data     TYPE STANDARD TABLE OF y_csv_line,
            w_csv_data     TYPE y_csv_line,
