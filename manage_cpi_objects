      CALL METHOD v_EDITOR->SET_SELECTED_TEXT_AS_R3TABLE
        EXPORTING
          TABLE    = t_texto_certificado
        EXCEPTIONS
          ERROR_DP = 1
          others   = 3.
*      CALL METHOD v_editor->free.
      free: W_SERVICE_KEY_NEW, V_OKCODE.
