                if l_http_rc = 200 or l_http_rc = 202.
                  w_csv_data-Status = c_starting.
                else.
                  w_csv_data-Status   = c_error.
                ENDIF."if l_http_rc = 200.

                modify T_csv_data from W_csv_data INDEX l_index.

                CONCATENATE w_csv_data-id w_csv_data-version W_csv_data-Status
                            INTO w_artifacts_deplo-line SEPARATED BY ';'.
                append w_artifacts_deplo to t_artifacts_deplo.

              ENDLOOP."LOOP AT t_csv_data INTO w_csv_data.

              v_alv->refresh_table_display( ).
              if P_E_UCOMM = 'UNDEPLO'.
                MESSAGE s000(oo) WITH TEXT-c16.
              else.
                MESSAGE s000(oo) WITH TEXT-c15.
              endif.

              if t_artifacts_deplo[] is NOT INITIAL.
*               Exibir artefatos alterados
