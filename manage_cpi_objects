        when 'PARAMETERVAL_CONF'.
          <f_fcat_local>-SCRTEXT_L = c_ParameterVal_conf.
        when 'UPDATED_CONF'.
          <f_fcat_local>-SCRTEXT_L = c_update_conf.
        when 'USER_CONF'.
