      l_percentage = ( sy-tabix / l_total2 ) * 100.
      CALL FUNCTION 'SAPGUI_PROGRESS_INDICATOR'
        EXPORTING
          percentage = l_percentage
          text       = l_msg_progress.

*     Relacionar SM59 configurada para ambiente BTP
      free: v_client.
      cl_http_client=>create_by_destination(
         EXPORTING destination = v_dest "SM59
         IMPORTING client      = v_client ).

*     Informar no Header o nome da interface a ser chamada
      CALL METHOD v_client->request->set_header_field
        EXPORTING
          name  = 'iflowname'
          value = 'IF_VSA_Artifacts_Get_Runtime'.

      CALL METHOD v_client->request->set_header_field
        EXPORTING
          name  = 'id'
          value = W_ARTIFACTS-ID_ART.

      v_client->request->set_method(  if_http_request=>co_request_method_post ).
      v_client->request->set_content_type( v_content_type ).

*     Chamada do Iflow
      v_client->send( ).
*     Retorno do Iflow
      v_client->receive( ).
*     Status do Iflow
      v_client->response->get_status( IMPORTING
                                        code   = l_http_rc
                                        reason = l_reason ).
*     Leitura do response
      l_response = v_client->response->get_cdata( ).
      free: v_client.

      if l_http_rc = 200.

*       XML para tabela interna
        CALL FUNCTION 'SCMS_STRING_TO_XSTRING'
          EXPORTING
            text   = l_response
          IMPORTING
            buffer = l_xstring
          EXCEPTIONS
            failed = 1
            OTHERS = 2.

        CALL FUNCTION 'SMUM_XML_PARSE'
          EXPORTING
            xml_input = l_xstring
          TABLES
            xml_table = t_xml_table
            return    = t_return.

        do.
*         Procura a tag Properties
          READ TABLE t_xml_table WITH KEY cname = 'properties' TRANSPORTING NO FIELDS.
          if sy-subrc ne 0.
*           Todos os pacotes lidos, sair do loop.
            exit.
          else.
            data(l_indice2) = sy-tabix.
            data(l_indice_limpeza2) = 1.
            do.
*             Elimina registros anteriores ao properties.
              delete t_xml_table index 1.
              l_indice_limpeza2 = l_indice_limpeza2 + 1.
              if l_indice_limpeza2 = l_indice2.
*                   Chegou no 'properties'
                delete t_xml_table INDEX 1."deleta 'properties'
                exit.
              endif.
            enddo.
          endif.

*         Artifact Type
          IF line_exists( t_xml_table[ cname = 'Type' ] ).
            w_artifacts-type_art_run             = t_xml_table[ cname = 'Type' ]-cvalue.
          endif.
*         Artifact DeployedBy
          IF line_exists( t_xml_table[ cname = 'DeployedBy' ] ).
            w_artifacts-DeployedBy_art_run       = t_xml_table[ cname = 'DeployedBy' ]-cvalue.
          endif.
*         Artifact DeployedOn
          IF line_exists( t_xml_table[ cname = 'DeployedOn' ] ).
            w_artifacts-DeployedOn_art_run       = t_xml_table[ cname = 'DeployedOn' ]-cvalue.
          endif.
*         Artifact Status
          IF line_exists( t_xml_table[ cname = 'Status' ] ).
            w_artifacts-Status_art_run           = t_xml_table[ cname = 'Status' ]-cvalue.
            case w_artifacts-Status_art_run.
              when 'STARTED'.
                w_artifacts-status_art_ico_run = '@08@'."'ICON_GREEN_LIGHT'.
              when '' or c_error.
                w_artifacts-status_art_ico_run = '@0A@'."'ICON_RED_LIGHT'.
              when 'STOPPING' or 'STARTING'.
                w_artifacts-status_art_ico_run = '@09@'."'ICON_YELLOW_LIGHT'.
            ENDCASE.
          endif.
          modify t_artifacts from w_artifacts index l_tabix_t_artifacts2.

        enddo.

      else.

        w_artifacts-Status_art_run     = c_Not_Deployed.
        w_artifacts-status_art_ico_run = '@0A@'."'@0A@'."'ICON_RED_LIGHT'.
        modify t_artifacts from w_artifacts index l_tabix_t_artifacts2.

      endif."if l_http_rc = 200. "IF_VSA_Artifacts_Get_Runtime

    endloop."at t_artifacts INTO w_artifacts.

  endif."  if p_verru is NOT INITIAL.


endform.

