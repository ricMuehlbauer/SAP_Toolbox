  CONSTANTS: c_Credentialsrs(10)  type c VALUE 'Credential',
             c_typsrs(4)          type c VALUE 'Type',
             c_Descriptionsrs(11) type c VALUE 'Description',
             c_usersrs(4)         type c VALUE 'User',
             c_Passsrs(4)         type c VALUE 'Pass',
             c_DeployedBysrs(10)  type c VALUE 'DeployedBy',
