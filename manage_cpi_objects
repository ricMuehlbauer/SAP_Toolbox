         W_SERVICE_KEY_NEW-name+0(4) = 'VSA_'   or
         W_SERVICE_KEY_NEW-name+0(5) = 'NEXA_' ).
        lv_ocorrencias = count( val = W_SERVICE_KEY_NEW-name sub = '_' ).
        if lv_ocorrencias < 2.
          MESSAGE W000(oo) with text-082.
        else.
*         Validar tela
          if W_SERVICE_KEY_NEW-KEYTYPECERTIFICATE is NOT INITIAL.
            if W_SERVICE_KEY_NEW-VALIDITY > 365.
              W_SERVICE_KEY_NEW-VALIDITY = 365.
              message W000(oo) WITH text-081.
              l_erro_tela = 'X'.
            endif.
          endif.
          if W_SERVICE_KEY_NEW-KEYTYPEextercertif is NOT INITIAL.
