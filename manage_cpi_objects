*&---------------------------------------------------------------------*
FORM zf_apply_filters_preenche.
  IF p_fsndpa IS NOT INITIAL AND p_fsndpa NE '*'.
    DELETE t_saida_alv_ico WHERE senderpartyid NS p_fsndpa.
  ENDIF.
  IF p_fsndco IS NOT INITIAL AND p_fsndco NE '*'.
    DELETE t_saida_alv_ico WHERE sendercomponentid NS p_fsndco.
  ENDIF.
  IF p_finter IS NOT INITIAL AND p_finter NE '*'.
    DELETE t_saida_alv_ico WHERE interfacename NS p_finter.
  ENDIF.
  IF p_fname IS NOT INITIAL AND p_fname NE '*'.
    DELETE t_saida_alv_ico WHERE interfacenamespace NS p_fname.
  ENDIF.
  IF p_frvid IS NOT INITIAL AND p_frvid NE '*'.
    DELETE t_saida_alv_ico WHERE receiverpartyid NS p_frvid.
  ENDIF.
  IF p_frvco IS NOT INITIAL AND p_frvco NE '*'.
    DELETE t_saida_alv_ico WHERE receivercomponentid NS p_frvco.
  ENDIF.
ENDFORM.

FORM zf_preenche_saida .
  FREE: t_saida_alv_ico.

  IF p_pi IS NOT INITIAL.
***********************************************
*   PI/PO
***********************************************
    IF p_ico IS NOT INITIAL OR
       p_pil IS NOT INITIAL.
***********************************************
*     ICO ou ICO controle LOG
***********************************************
      LOOP AT w_input_ico_query-integrated_configuration_query-integrated_configuration_id
              REFERENCE INTO DATA(w_input_ico_config).
        CLEAR: w_saida_alv_ico.
        w_saida_alv_ico-senderpartyid       = w_input_ico_config->sender_party_id.
        w_saida_alv_ico-sendercomponentid   = w_input_ico_config->sender_component_id.
        w_saida_alv_ico-interfacename       = w_input_ico_config->interface_name.
        w_saida_alv_ico-interfacenamespace  = w_input_ico_config->interface_namespace.
        w_saida_alv_ico-receiverpartyid     = w_input_ico_config->receiver_party_id.
        w_saida_alv_ico-receivercomponentid = w_input_ico_config->receiver_component_id.
        APPEND w_saida_alv_ico TO t_saida_alv_ico.
      ENDLOOP.

      PERFORM zf_apply_filters_preenche.

      SORT t_saida_alv_ico BY sendercomponentid interfacenamespace interfacename receiverpartyid receivercomponentid.

      DESCRIBE TABLE  t_saida_alv_ico LINES v_qtd_ico.
      MESSAGE s000(oo) WITH v_qtd_ico TEXT-002.
    ELSE.
***********************************************
*     Communication Channel
***********************************************
      LOOP AT w_input_cc_query-communication_channel_query_re-communication_channel_id
              REFERENCE INTO DATA(w_communication_channel_id).
        CLEAR: w_saida_alv_cc.
        w_saida_alv_cc-partyid      = w_communication_channel_id->party_id.
        w_saida_alv_cc-componentid  = w_communication_channel_id->component_id.
        w_saida_alv_cc-channelid    = w_communication_channel_id->channel_id.
        APPEND w_saida_alv_cc TO t_saida_alv_cc.
      ENDLOOP.

      SORT t_saida_alv_cc BY partyid componentid channelid.

      DESCRIBE TABLE  t_saida_alv_cc LINES v_qtd_cc.
      MESSAGE s000(oo) WITH v_qtd_cc TEXT-008.


    ENDIF.
  ELSE.
***********************************************
*   GRC
***********************************************
    IF p_ico IS NOT INITIAL.
***********************************************
*    ICO - GRC
***********************************************
      LOOP AT w_input_ico_grc_query-integrated_configuration_query-integrated_configuration_id
              REFERENCE INTO DATA(w_input_ico_grc_config).
        CLEAR: w_saida_alv_ico.
        w_saida_alv_ico-senderpartyid       = w_input_ico_grc_config->sender_party_id.
        w_saida_alv_ico-sendercomponentid   = w_input_ico_grc_config->sender_component_id.
        w_saida_alv_ico-interfacename       = w_input_ico_grc_config->interface_name.
        w_saida_alv_ico-interfacenamespace  = w_input_ico_grc_config->interface_namespace.
        w_saida_alv_ico-receiverpartyid     = w_input_ico_grc_config->receiver_party_id.
        w_saida_alv_ico-receivercomponentid = w_input_ico_grc_config->receiver_component_id.
*       Filtro de registros
        IF p_fsndpa IS NOT INITIAL AND
           p_fsndpa NE '*'.
          IF w_saida_alv_ico-senderpartyid NS p_fsndpa.
*           Desprezar registro por Sender Party
            CONTINUE.
          ENDIF.
        ENDIF.
        IF p_fsndco IS NOT INITIAL AND
           p_fsndco NE '*'.
          IF w_saida_alv_ico-sendercomponentid NS p_fsndco.
*           Desprezar registro por Sender COmponent
            CONTINUE.
          ENDIF.
        ENDIF.
        IF p_finter IS NOT INITIAL AND
           p_finter NE '*'.
          IF w_saida_alv_ico-interfacename NS p_finter.
*           Desprezar registro por interface
            CONTINUE.
          ENDIF.
        ENDIF.
        IF p_finter IS NOT INITIAL AND
           p_finter NE '*'.
          IF w_saida_alv_ico-interfacename NS p_finter.
*           Desprezar registro por interface
            CONTINUE.
          ENDIF.
        ENDIF.
        IF p_fname IS NOT INITIAL AND
           p_fname NE '*'.
          IF w_saida_alv_ico-interfacenamespace NS p_fname.
*           Desprezar registro por namescape
            CONTINUE.
          ENDIF.
        ENDIF.
        IF p_frvid  IS NOT INITIAL AND
           p_frvid  NE '*'.
          IF w_saida_alv_ico-receiverpartyid NS p_frvid.
*           Desprezar registro por REceiver Party
