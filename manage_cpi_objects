*&---------------------------------------------------------------------*
*&     Form zf_get_Integrationartifacts
*&---------------------------------------------------------------------*
*&---------------------------------------------------------------------*
FORM zf_get_Integrationartifacts.
  data: l_http_rc   type sy-subrc,
        l_reason    type String,
        l_response  TYPE string,
        l_xstring   TYPE xstring,
        t_return    TYPE TABLE OF bapiret2,
        t_xml_table TYPE TABLE OF smum_xmltb.


  MESSAGE s000(oo) with text-C04 w_artifacts-name_pk.

* Relacionar SM59 configurada para ambiente BTP
  free: v_client.
  cl_http_client=>create_by_destination(
     EXPORTING destination = v_dest "SM59
     IMPORTING client      = v_client ).

* Informar no Header o nome da interface a ser chamada
  CALL METHOD v_client->request->set_header_field
    EXPORTING
      name  = 'iflowname'
      value = 'IF_VSA_Artifacts_Get_IntegrationPackages'.

  v_client->request->set_method(  if_http_request=>co_request_method_post ).
  v_client->request->set_content_type( v_content_type ).
* Chamada do Iflow
  v_client->send( ).
* Retorno do Iflow
  v_client->receive( ).
* Status do Iflow
  v_client->response->get_status( IMPORTING
                                    code   = l_http_rc
                                    reason = l_reason ).
* Leitura do response
  l_response = v_client->response->get_cdata( ).
  free: v_client.

  if l_http_rc = 200.

* XML para tabela interna
    CALL FUNCTION 'SCMS_STRING_TO_XSTRING'
      EXPORTING
        text   = l_response
      IMPORTING
        buffer = l_xstring
      EXCEPTIONS
        failed = 1
        OTHERS = 2.

    CALL FUNCTION 'SMUM_XML_PARSE'
      EXPORTING
        xml_input = l_xstring
      TABLES
        xml_table = t_xml_table
        return    = t_return.

    free: t_artifacts.

    do.
*   Procura a tag Properties
      READ TABLE t_xml_table WITH KEY cname = 'properties' TRANSPORTING NO FIELDS.
      if sy-subrc ne 0.
*     Todos os pacotes lidos, sair do loop.
        exit.
      else.
        data(l_indice) = sy-tabix.
        data(l_indice_limpeza) = 1.
        do.
*       Elimina registros anteriores ao properties.
          delete t_xml_table index 1.
          l_indice_limpeza = l_indice_limpeza + 1.
          if l_indice_limpeza = l_indice.
*         Chegou no 'properties'
            delete t_xml_table INDEX 1."deleta 'properties'
            exit.
          endif.
        enddo.

        clear: w_artifacts.
*       Pacote ID
        w_artifacts-id_pk                 = t_xml_table[ cname = 'Id' ]-cvalue.
*       Nome do Pacote
        w_artifacts-name_pk               = t_xml_table[ cname = 'Name' ]-cvalue.
*       Criador do Pacote
        w_artifacts-CreatedBy_pk          = t_xml_table[ cname = 'CreatedBy' ]-cvalue.
*       Data Criação do Pacote
        w_artifacts-CreationDate_pk       = t_xml_table[ cname = 'CreationDate' ]-cvalue.
*       Modificação do Pacote
        w_artifacts-ModifiedBy_pk         = t_xml_table[ cname = 'ModifiedBy' ]-cvalue.
*       Data da Modificação do Pacote
        w_artifacts-ModifiedDate_pk       = t_xml_table[ cname = 'ModifiedDate' ]-cvalue.
*       Palavra chave do pacote
        READ TABLE t_xml_table into data(w_xml_table) WITH KEY cname = 'Keywords'.
        IF sy-subrc = 0.
          w_artifacts-keyword_pk = w_xml_table-cvalue.
        endif.
        append w_artifacts to t_artifacts.

      endif.
    enddo.

*   Filtro de Package
    if P_CPIPK is NOT INITIAL.
      if P_CPIPK ns '*'.
        delete t_artifacts WHERE name_pk ne P_CPIPK.
      endif.
      if P_CPIPK cs '*'.
        delete t_artifacts WHERE name_pk np P_CPIPK.
      endif.
    endif.

  endif."if l_http_rc = 200.

  if t_artifacts[] is INITIAL.
*   Sem dados para seleção.
    MESSAGE s000(oo) WITH TEXT-C01 DISPLAY LIKE 'E'.
    stop.
  endif.

ENDFORM.   "zf_get_Integrationartifacts


