FORM zf_convert_date CHANGING P_W_ARTIFACTS_MODIFIEDAT_ART.
  DATA: l_unix_timestamp TYPE string,
        l_date_utc       TYPE datum,
        l_time_utc       TYPE uzeit,
        l_millisecond    TYPE num03,
        l_iso_format     TYPE string.

*formato timestamp em milissegundos desde a Época Unix (Unix Epoch),
*que é o número de milissegundos passados desde 1º de janeiro de 1970, 00:00:00 UTC.*

  if P_W_ARTIFACTS_MODIFIEDAT_ART is NOT INITIAL.

    l_unix_timestamp = P_W_ARTIFACTS_MODIFIEDAT_ART.

    CALL METHOD cl_pco_utility=>convert_java_timestamp_to_abap
      EXPORTING
        iv_timestamp = l_unix_timestamp
      IMPORTING
        ev_date      = l_date_utc
        ev_time      = l_time_utc
        ev_msec      = l_millisecond.

    " Formatar no padrão ISO 8601 (YYYY-MM-DDThh:mm:ss.SSSZ)
    l_iso_format = |{ l_date_utc+0(4) }-{ l_date_utc+4(2) }-{ l_date_utc+6(2) }T| &&
                   |{ l_time_utc+0(2) }:{ l_time_utc+2(2) }:{ l_time_utc+4(2) }.| &&
                   |{ l_millisecond }Z|.

    P_W_ARTIFACTS_MODIFIEDAT_ART = l_iso_format.

  endif.

ENDFORM.   "zf_convert_date

