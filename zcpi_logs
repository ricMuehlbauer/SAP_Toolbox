          REPLACE 'AMBIENTE' IN l_url WITH 'prd'.
        else.
          REPLACE 'AMBIENTE' IN l_url WITH 'dev'.
        endif.
        REPLACE 'GUID' IN l_url WITH w_ztbbc_log_cpi3->Messageid.

        CALL FUNCTION 'CALL_BROWSER'
          EXPORTING
            URL                    = l_url
          EXCEPTIONS
            FRONTEND_NOT_SUPPORTED = 1
            FRONTEND_ERROR         = 2
            PROG_NOT_FOUND         = 3
            NO_BATCH               = 4
            UNSPECIFIED_ERROR      = 5
            OTHERS                 = 6.
      endif.

    elseif P_E_COLUMN eq 'CORRELATIONID'.
*     Abre URL no Navegador
      READ TABLE T_ZTBBC_LOG_CPI REFERENCE INTO data(w_ztbbc_log_cpi4) INDEX P_E_ROW-index.
      if sy-subrc eq 0 and w_ztbbc_log_cpi4->Messageid ne ''.
