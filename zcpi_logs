*************************************************************************
*INITIALIZATION.
*************************************************************************
INITIALIZATION.
  perform zf_ajusta_horas.
  p_dthora = text-020.

*************************************************************************
*AT SELECTION-SCREEN OUTPUT.
*************************************************************************
AT SELECTION-SCREEN OUTPUT.
  PERFORM zf_loopatscreen.

AT SELECTION-SCREEN.
  IF sy-ucomm = 'DTHORA'.
    perform zf_ajusta_horas.
  ENDIF.

************************************************************************
*START-OF-SELECTION.
************************************************************************
START-OF-SELECTION.

  perform zf_saneamento_log.
*******************************************************************
* BTP - Integration Suite
*******************************************************************
  if p_btp is NOT INITIAL.

    if p_zdata1 is INITIAL or p_zdata2 is INITIAL or
       p_zhora1 is INITIAL or p_zhora2 is INITIAL.
      MESSAGE text-018 TYPE 'I'.
      stop.
    else.
      if ( P_custna is NOT INITIAL and P_custva is INITIAL ) or
         ( P_custva is not INITIAL and P_custna is INITIAL ).
        MESSAGE text-032 TYPE 'I'.
        stop.
      else.
*       Busca LOG
        perform zf_message_log.
        if t_messagelogs[] is INITIAL.
*         Sem dados para seleção.
          MESSAGE s000(oo) WITH TEXT-019 DISPLAY LIKE 'E'.
          stop.
        else.
          CALL SCREEN 200.
        endif.

      endif.
    endif.

  endif."  if p_btp is NOT INITIAL.

*******************************************************************
* SAP
*******************************************************************
  if p_sap is NOT INITIAL.

    if s_bukrs[] is INITIAL.
      MESSAGE text-017 TYPE 'I'.
      stop.
    else.

      PERFORM zf_autorizacao.
      IF t_ZTBBC_LOG_CPI[] IS INITIAL.
        MESSAGE text-003 TYPE 'I'.
        stop.
      else.
        if p_est is NOT INITIAL.
          free: t_estatistica.
          perform zf_estatisticas.
        endif.
        CALL SCREEN 100.
      ENDIF.

    ENDIF.

  ENDIF."  if p_sap is NOT INITIAL.


