*&---------------------------------------------------------------------*
MODULE ZF_STATUS_0100 OUTPUT.
  DATA: t_sort TYPE lvc_t_sort,
        w_sort TYPE lvc_s_sort.

  SET PF-STATUS 'ZGSD_LOG'.

********************************************
* Log
********************************************
  if p_log is  NOT INITIAL.
    IF v_init is initial.

      if p_hor eq 'X'.
        v_splitter_main = new #(
                                 parent = cl_gui_container=>default_screen
*                           nv_autodef_progid_dynnr = abap_true
                                 rows                    = 2
                                 columns                 = 1 ).
        v_container_o = v_splitter_main->get_container( row = 1 column = 1 ).
        v_container_u = v_splitter_main->get_container( row = 2 column = 1 ).
      else.
        v_splitter_main = new #(
                                 parent = cl_gui_container=>default_screen
*                           nv_autodef_progid_dynnr = abap_true
                                 rows                    = 1
                                 columns                 = 2 ).
        v_container_o = v_splitter_main->get_container( row = 1 column = 1 ).
        v_container_u = v_splitter_main->get_container( row = 1 column = 2 ).
      endif.
      v_splitter_main->set_column_width( id = 1 width = 60 ).

      data(v_alv) = new cl_gui_alv_grid( i_parent      = v_container_o " in default container einbetten
                                         i_appl_events = abap_true ).                     " Ereignisse als Applikationsevents registrieren

      data: v_salv type ref to cl_salv_table.

      cl_salv_table=>factory( importing
                                r_salv_table = v_salv
                              changing
                                t_table      = t_ZTBBC_LOG_CPI ).
      data(t_fcat) = cl_salv_controller_metadata=>get_lvc_fieldcatalog( r_columns      = v_salv->get_columns( )

                                                                         r_aggregations = v_salv->get_aggregations( ) ).

      delete t_fcat where FieldNAME = 'MANDT'.
      delete t_fcat where FieldNAME = 'TIMESTAMP'.
      loop at t_fcat ASSIGNING FIELD-SYMBOL(<f_fcat>).
        if <f_fcat>-fieldname = 'MATNR' or
           <f_fcat>-fieldname = 'LIFNR' or
           <f_fcat>-fieldname = 'KUNNR' or
           <f_fcat>-fieldname = 'PERNR' or
           <f_fcat>-fieldname = 'EBELN' or
           <f_fcat>-fieldname = 'BANFN' or
           <f_fcat>-fieldname = 'VBELN' or
           <f_fcat>-fieldname = 'COD_PROCESSO' or
           <f_fcat>-fieldname = 'USUARIO'.
          clear: <f_fcat>-key.
        endif.
        case <f_fcat>-fieldname.
          when 'ICONE'.
            <f_fcat>-SCRTEXT_L = text-029.
            <f_fcat>-outputlen = 5.
          when 'ICONEBTP'.
            <f_fcat>-SCRTEXT_L = text-034.
            <f_fcat>-outputlen = 4.
        ENDCASE.
        <f_fcat>-REPTEXT   = <f_fcat>-SCRTEXT_L.
        <f_fcat>-SCRTEXT_M = <f_fcat>-SCRTEXT_L.
        <f_fcat>-SCRTEXT_S = <f_fcat>-SCRTEXT_L.
      endloop.

      data(v_layout) = value lvc_s_layo(
                                            zebra      = abap_true
                                            cwidth_opt = 'A'
                                            grid_title = text-004
                                            COL_OPT    =  abap_true
                                          ).

      free: t_sort.
      w_sort-fieldname = 'BUKRS'.
      w_sort-up = 'X'.
      APPEND w_sort TO t_sort.

      w_sort-fieldname = 'DATA'.
      w_sort-up = 'X'.
      APPEND w_sort TO t_sort.

      w_sort-fieldname = 'HORA'.
      w_sort-up = 'X'.
      APPEND w_sort TO t_sort.

      w_sort-fieldname = 'IFLOW'.
      w_sort-up = 'X'.
      APPEND w_sort TO t_sort.

      w_sort-fieldname = 'PROGRAMA'.
      w_sort-up = 'X'.
      APPEND w_sort TO t_sort.

      w_sort-fieldname = 'DIRECAO'.
      w_sort-up = 'X'.
      APPEND w_sort TO t_sort.

      data v_variant_det type disvariant.
      v_variant_det-report   = sy-repid.
      v_variant_det-username = sy-uname.

      CREATE OBJECT v_event_handler.
      SET HANDLER v_event_handler->on_user_command FOR v_alv.
      SET HANDLER v_event_handler->handle_double_click FOR v_alv.

      v_alv->set_table_for_first_display( exporting
                                            i_bypassing_buffer = abap_false  " Puffer ausschalten
                                            i_save             = 'A'         " Anzeigevariante sichern
                                            is_layout          = v_layout   " Layout
                                            is_variant         = v_variant_det

                                          changing
                                            it_fieldcatalog    = t_fcat     " Feldkatalog
                                            it_sort            = t_sort
                                            it_outtab          = t_ZTBBC_LOG_CPI ). " Ausgabetabelle

      CREATE OBJECT v_editor
        EXPORTING
          parent = v_container_u.
      v_editor->set_readonly_mode( 1 ).

      cl_gui_alv_grid=>set_focus( control = v_alv ).
      cl_abap_list_layout=>suppress_toolbar( ).

      v_init = 'X'.

      CALL METHOD cl_gui_cfw=>flush
        EXCEPTIONS
          cntl_system_error = 1
          cntl_error        = 2.

    ENDIF."IF v_init is initial.
  endif. "  if p_log is  NOT INITIAL.

********************************************
* Estatísticas
********************************************
  if p_est is NOT INITIAL.

    data(v_alv2) = new cl_gui_alv_grid( i_parent      = cl_gui_container=>default_screen " in default container einbetten
                                       i_appl_events = abap_true ).                     " Ereignisse als Applikationsevents registrieren

    data: v_ealv type ref to cl_salv_table.

    IF v_init is initial.
*     Somente ALV sem envio.
      cl_salv_table=>factory( importing
                                r_salv_table = v_ealv
                              changing
                                t_table      = t_estatistica ).
      data(t_fcat_local) = cl_salv_controller_metadata=>get_lvc_fieldcatalog( r_columns      = v_ealv->get_columns( )

                                                                         r_aggregations = v_ealv->get_aggregations( ) ).

      delete t_fcat_local where FieldNAME = 'MANDT'.

      loop at t_fcat_local ASSIGNING FIELD-SYMBOL(<f_fcat_local>).
        case <f_fcat_local>-fieldname.
          when 'QTDE_BUKRS'.
            <f_fcat_local>-SCRTEXT_L = <f_fcat_local>-SCRTEXT_m = <f_fcat_local>-SCRTEXT_s = text-009.
            <f_fcat_local>-do_sum = abap_true.
            clear <f_fcat_local>-no_sum.
          when 'QTDE_IFLOW'.
            <f_fcat_local>-SCRTEXT_L = <f_fcat_local>-SCRTEXT_m = <f_fcat_local>-SCRTEXT_s = text-010.
            <f_fcat_local>-do_sum = abap_true.
            clear <f_fcat_local>-no_sum.
          when 'MSG_SIZE'.
            <f_fcat_local>-SCRTEXT_L = <f_fcat_local>-SCRTEXT_m = <f_fcat_local>-SCRTEXT_s = text-012.
            <f_fcat_local>-do_sum = abap_true.
            clear <f_fcat_local>-no_sum.
          when 'MSG_SIZE_KB'.
            <f_fcat_local>-SCRTEXT_L = <f_fcat_local>-SCRTEXT_m = <f_fcat_local>-SCRTEXT_s = text-013.
            <f_fcat_local>-do_sum = abap_true.
            clear <f_fcat_local>-no_sum.
          when 'MSG_SIZE_MB'.
            <f_fcat_local>-SCRTEXT_L = <f_fcat_local>-SCRTEXT_m = <f_fcat_local>-SCRTEXT_s = text-014.
            <f_fcat_local>-do_sum = abap_true.
            clear <f_fcat_local>-no_sum.
        endcase.
      endloop.

      data(v_layout_local) = value lvc_s_layo(
                                            zebra      = abap_true
                                            cwidth_opt = 'A'
                                            grid_title = text-004
                                          ).

      free: t_sort.
      w_sort-fieldname = 'BUKRS'.
      w_sort-up = 'X'.
      APPEND w_sort TO t_sort.

      w_sort-fieldname = 'IFLOW'.
      w_sort-up = 'X'.
      APPEND w_sort TO t_sort.

      if  p_estb is INITIAL."Não detalhar
        delete t_sort WHERE fieldname = 'IFLOW'.
        delete t_fcat_local WHERE fieldname = 'IFLOW'.
        delete t_fcat_local WHERE fieldname = 'QTDE_IFLOW'.
      endif.

      data v_variant_det_local type disvariant.
      v_variant_det_local-report   = sy-repid.
      v_variant_det_local-username = sy-uname.

*      CREATE OBJECT v_event_handler.
*      SET HANDLER v_event_handler->on_user_command     FOR v_alv.
*      SET HANDLER v_event_handler->handle_double_click FOR v_alv.
*      SET HANDLER v_event_handler->on_toolbar          FOR v_alv.

      v_alv2->set_table_for_first_display( exporting
                                            i_bypassing_buffer = abap_false " Puffer ausschalten
                                            i_save             = 'A'         " Anzeigevariante sichern
                                            is_layout          = v_layout_local   " Layout
                                            is_variant         = v_variant_det_local

                                          changing
                                            it_fieldcatalog    = t_fcat_local     " Feldkatalog
                                            it_sort            = t_sort
                                            it_outtab          = t_estatistica ). " Ausgabetabelle

      cl_gui_alv_grid=>set_focus( control = v_alv2 ).
      cl_abap_list_layout=>suppress_toolbar( ).

      v_init = 'X'.

      CALL METHOD cl_gui_cfw=>flush
        EXCEPTIONS
          cntl_system_error = 1
          cntl_error        = 2.
    endif.
  endif."  if p_est is NOT INITIAL.

ENDMODULE.


*&---------------------------------------------------------------------*
*& Module STATUS_0200 OUTPUT
*&---------------------------------------------------------------------*
MODULE ZF_STATUS_0200 OUTPUT.
  DATA: t_sort_btp TYPE lvc_t_sort,
        w_sort_btp TYPE lvc_s_sort.

  SET PF-STATUS 'ZGSD_LOG'.

********************************************
* Log Integration Suite
********************************************
  IF v_init_btp is initial.

    if p_hor eq 'X'.
      v_splitter_main_btp = new #(
                               parent = cl_gui_container=>default_screen
*                           nv_autodef_progid_dynnr = abap_true
                               rows                    = 2
                               columns                 = 1 ).
      v_container_btp_o = v_splitter_main_btp->get_container( row = 1 column = 1 ).
      v_container_btp_u = v_splitter_main_btp->get_container( row = 2 column = 1 ).
    else.
      v_splitter_main_btp = new #(
                               parent = cl_gui_container=>default_screen
*                           nv_autodef_progid_dynnr = abap_true
                               rows                    = 1
                               columns                 = 2 ).
      v_container_btp_o = v_splitter_main_btp->get_container( row = 1 column = 1 ).
      v_container_btp_u = v_splitter_main_btp->get_container( row = 1 column = 2 ).
    endif.
    v_splitter_main_btp->set_column_width( id = 1 width = 65 ).

    data(v_alv_btp) = new cl_gui_alv_grid( i_parent      = v_container_btp_o " in default container einbetten
                                       i_appl_events = abap_true ).                     " Ereignisse als Applikationsevents registrieren

    data: v_salv_btp type ref to cl_salv_table.

    cl_salv_table=>factory( importing
                              r_salv_table = v_salv_btp
                            changing
                              t_table      = t_messagelogs ).
    data(t_fcat_btp) = cl_salv_controller_metadata=>get_lvc_fieldcatalog( r_columns      = v_salv_btp->get_columns( )

                                                                       r_aggregations = v_salv_btp->get_aggregations( ) ).


    delete t_fcat_btp where FieldNAME = 'LOGSTART'.
    delete t_fcat_btp where FieldNAME = 'LOGEND'.
    delete t_fcat_btp where FieldNAME = 'CUSTOMSTATUS'.
    delete t_fcat_btp where FieldNAME = 'ORIGINCOMPONENTNAME'.
    delete t_fcat_btp where FieldNAME = 'LOCALCOMPONENTNAME'.
    delete t_fcat_btp where FieldNAME = 'TRANSACTIONID'.
    delete t_fcat_btp where FieldNAME = 'CORRELATIONID'.
    delete t_fcat_btp where FieldNAME = 'DATAGMT'.
    delete t_fcat_btp where FieldNAME = 'HORAGMT'.
    loop at t_fcat_btp ASSIGNING FIELD-SYMBOL(<f_fcat_btp>).
      if <f_fcat_btp>-fieldname = 'INTEGRATIONFLOWNAME' or
         <f_fcat_btp>-fieldname = 'DATA' or
         <f_fcat_btp>-fieldname = 'HORA'.
        <f_fcat_btp>-key = 'X'.
      endif.

      case <f_fcat_btp>-fieldname.
        when 'INTEGRATIONFLOWNAME'.
          <f_fcat_btp>-SCRTEXT_L = Text-021.
          <f_fcat_btp>-outputlen = 60.
        when 'STATUS'.
          <f_fcat_btp>-SCRTEXT_L = text-022.
          <f_fcat_btp>-outputlen = 10.
        when 'DATA'.
          <f_fcat_btp>-SCRTEXT_L = text-023.
          <f_fcat_btp>-outputlen = 10.
        when 'HORA'.
          <f_fcat_btp>-SCRTEXT_L = text-024.
          <f_fcat_btp>-outputlen = 8.
        when 'DATAGMT'.
          <f_fcat_btp>-SCRTEXT_L = text-030.
          <f_fcat_btp>-outputlen = 10.
        when 'HORAGMT'.
          <f_fcat_btp>-SCRTEXT_L = text-031.
          <f_fcat_btp>-outputlen = 8.
        when 'MESSAGEGUID'.
          <f_fcat_btp>-SCRTEXT_L = text-025.
          <f_fcat_btp>-outputlen = 30.
        when 'LOCALCOMPONENTNAME'.
          <f_fcat_btp>-SCRTEXT_L = text-027.
          <f_fcat_btp>-outputlen = 15.
        when 'LOGLEVEL'.
          <f_fcat_btp>-SCRTEXT_L = text-028.
          <f_fcat_btp>-outputlen = 10.
      endcase.
      <f_fcat_btp>-REPTEXT   = <f_fcat_btp>-SCRTEXT_L.
      <f_fcat_btp>-SCRTEXT_M = <f_fcat_btp>-SCRTEXT_L.
      <f_fcat_btp>-SCRTEXT_S = <f_fcat_btp>-SCRTEXT_L.
    endloop.

