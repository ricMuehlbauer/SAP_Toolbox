            FRONTEND_ERROR         = 2
            PROG_NOT_FOUND         = 3
            NO_BATCH               = 4
            UNSPECIFIED_ERROR      = 5
            OTHERS                 = 6.
      endif.

    else.
*     Mostrar log no SAP
      READ TABLE t_ztbbc_log_cpi REFERENCE INTO data(w_ztbbc_log_cpi)
                                 INDEX P_ES_ROW_NO-ROW_ID.
      IF sy-subrc = 0.
        l_iflowauth = w_ztbbc_log_cpi->iflow.
        AUTHORITY-CHECK OBJECT 'ZO:IFLOW02'
        ID 'ACTVT' FIELD '03'
        ID 'IFLOW' FIELD l_iflowauth.
        IF SY-SUBRC <> 0.
