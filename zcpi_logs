*&---------------------------------------------------------------------*
*& -->  p1        text
*& <--  p2        text
*&---------------------------------------------------------------------*
FORM zf_message_log .
  data: l_http_rc          type sy-subrc,
        l_reason           type String,
        l_string           type String,
        l_response         TYPE string,
        l_xstring          TYPE xstring,
        t_return           TYPE TABLE OF bapiret2,
        t_xml_table        TYPE TABLE OF smum_xmltb,
        l_client           TYPE REF TO if_http_client,
        l_dest             TYPE rfcdest,
        l_content_type     type String VALUE 'application/json',
        l_param            type ZDEGL_PARAM value 'VSADEV',
        t_ztbbc_parametros TYPE TABLE OF ztbbc_parametros,
        l_fuso             type INT4,
        l_data_fuso        type sy-datum,
        l_data_hora        type sy-uzeit.

  if sy-host cs '05c' or sy-host cs '05a'.
*   Muda para parâmetros de Produção
    l_param = 'VSAPRD'.
  endif.

  CALL FUNCTION 'ZFSD_CONSTANTES1'
    EXPORTING
      I_CODE           = 'ZCPI_LOGS'
      I_PARAM          = l_param
    TABLES
      ZTBBC_PARAMETROS = t_ztbbc_parametros
    EXCEPTIONS
      NOT_FOUND        = 1
      OTHERS           = 2.

  IF line_exists( t_ztbbc_parametros[ zparam = l_param ] ).
    l_dest =  t_ztbbc_parametros[ zparam = l_param ]-zvlpar.
  endif.

* Relacionar SM59 configurada para ambiente BTP
  free: l_client.
  cl_http_client=>create_by_destination(
     EXPORTING destination = l_dest "SM59
     IMPORTING client      = l_client ).

  if P_msgid is NOT INITIAL or
     P_corid is NOT INITIAL.
*    Busca direta pelo GUID

*   Informar no Header o nome da interface a ser chamada
    CALL METHOD l_client->request->set_header_field
      EXPORTING
        name  = 'iflowname'
        value = 'IF_VSA_MANAGEMENT_Get_MessageLog'.

    if P_corid is NOT INITIAL.
      l_string = 'CorrelationId%20eq%20%27GUID%27'.
      REPLACE 'GUID' IN l_string WITH P_corid.
    endif.

    if P_msgid is NOT INITIAL.
      l_string = 'MessageGuid%20eq%20%27GUID%27'.
      REPLACE 'GUID' IN l_string WITH P_msgid.
    endif.

    CALL METHOD l_client->request->set_header_field
      EXPORTING
        name  = 'guid'
        value = l_string.

  else.

    if P_custna is NOT INITIAL and P_custva is NOT INITIAL.
*     Custom Header Informado
      CALL METHOD l_client->request->set_header_field
        EXPORTING
          name  = 'iflowname'
          value = 'IF_VSA_MANAGEMENT_Get_MessageLogCustomHeader'.

      if p_ziflow cs '*'.
        l_string = p_ziflow.
        TRANSLATE l_string USING '* '.
      else.
        l_string = p_ziflow.
      endif.

      CALL METHOD l_client->request->set_header_field
        EXPORTING
          name  = 'iflownamelog'
          value = l_string.
      l_fuso = p_fuso.
      l_fuso = l_fuso * -1.
      if p_dst is NOT INITIAL.
        l_fuso =  l_fuso - 1.
      endif.

*     Ajusta fuso horário dataDE
*     A busca é sempre feito pelo GMT
      CALL FUNCTION 'IGN_TIMESTAMP_PLUSMINUS'
        EXPORTING
          START_DATE      = p_zdata1
          START_TIME      = p_zhora1
          FORWARD         = 'X'
          BACKWARD        = ''
          HOURS           = l_fuso
        IMPORTING
          RESULT_DATE     = l_data_fuso
          RESULT_TIME     = l_data_hora
        EXCEPTIONS
          PARAMETER_ERROR = 1
          OTHERS          = 2.

      concatenate l_data_fuso+0(4) '-' l_data_fuso+4(2) '-' l_data_fuso+6(2) 'T'
                  l_data_hora+0(2) ':' l_data_hora+2(2) ':' l_data_hora+4(2)
                  into l_string.
      CALL METHOD l_client->request->set_header_field
        EXPORTING
          name  = 'logstart'
          value = l_string.

*     Ajusta fuso horário dataATé
*     A busca é sempre feito pelo GMT
      CALL FUNCTION 'IGN_TIMESTAMP_PLUSMINUS'
        EXPORTING
          START_DATE      = p_zdata2
          START_TIME      = p_zhora2
          FORWARD         = 'X'
          BACKWARD        = ''
          HOURS           = l_fuso
        IMPORTING
          RESULT_DATE     = l_data_fuso
          RESULT_TIME     = l_data_hora
        EXCEPTIONS
          PARAMETER_ERROR = 1
          OTHERS          = 2.

      concatenate l_data_fuso+0(4) '-' l_data_fuso+4(2) '-' l_data_fuso+6(2) 'T'
                  l_data_hora+0(2) ':' l_data_hora+2(2) ':' l_data_hora+4(2)
                  into l_string.
      CALL METHOD l_client->request->set_header_field
        EXPORTING
          name  = 'logend'
          value = l_string.

      CALL METHOD l_client->request->set_header_field
        EXPORTING
          name  = 'guid'
          value = ''.

      CONCATENATE P_custna '''' '%20eq%20' '''' P_custva into l_string.
      CALL METHOD l_client->request->set_header_field
        EXPORTING
          name  = 'custheader'
          value = l_string.

      l_string = P_Zstat.
      if P_Zstat = ''. l_string = 'All'. endif.
      CALL METHOD l_client->request->set_header_field
        EXPORTING
          name  = 'iflowstatus'
          value = l_string.

    else.
*     Informar no Header o nome da interface a ser chamada
      CALL METHOD l_client->request->set_header_field
        EXPORTING
          name  = 'iflowname'
          value = 'IF_VSA_MANAGEMENT_Get_MessageLog'.

      if p_ziflow cs '*'.
        l_string = p_ziflow.
        TRANSLATE l_string USING '* '.
      else.
        l_string = p_ziflow.
      endif.
      CALL METHOD l_client->request->set_header_field
        EXPORTING
          name  = 'iflownamelog'
          value = l_string.

      l_fuso = p_fuso.
      l_fuso = l_fuso * -1.
      if p_dst is NOT INITIAL.
        l_fuso =  l_fuso - 1.
      endif.

*     Ajusta fuso horário dataDE
*     A busca é sempre feito pelo GMT
      CALL FUNCTION 'IGN_TIMESTAMP_PLUSMINUS'
        EXPORTING
          START_DATE      = p_zdata1
          START_TIME      = p_zhora1
          FORWARD         = 'X'
          BACKWARD        = ''
          HOURS           = l_fuso
        IMPORTING
          RESULT_DATE     = l_data_fuso
          RESULT_TIME     = l_data_hora
        EXCEPTIONS
          PARAMETER_ERROR = 1
          OTHERS          = 2.

      concatenate l_data_fuso+0(4) '-' l_data_fuso+4(2) '-' l_data_fuso+6(2) 'T'
                  l_data_hora+0(2) ':' l_data_hora+2(2) ':' l_data_hora+4(2)
                  into l_string.
      CALL METHOD l_client->request->set_header_field
        EXPORTING
          name  = 'logstart'
          value = l_string.

*     Ajusta fuso horário dataATé
*     A busca é sempre feito pelo GMT
      CALL FUNCTION 'IGN_TIMESTAMP_PLUSMINUS'
        EXPORTING
          START_DATE      = p_zdata2
          START_TIME      = p_zhora2
          FORWARD         = 'X'
          BACKWARD        = ''
          HOURS           = l_fuso
        IMPORTING
          RESULT_DATE     = l_data_fuso
          RESULT_TIME     = l_data_hora
        EXCEPTIONS
          PARAMETER_ERROR = 1
          OTHERS          = 2.

      concatenate l_data_fuso+0(4) '-' l_data_fuso+4(2) '-' l_data_fuso+6(2) 'T'
                  l_data_hora+0(2) ':' l_data_hora+2(2) ':' l_data_hora+4(2)
                  into l_string.
      CALL METHOD l_client->request->set_header_field
        EXPORTING
          name  = 'logend'
          value = l_string.

      CALL METHOD l_client->request->set_header_field
        EXPORTING
          name  = 'guid'
          value = ''.

      l_string = P_Zstat.
      if P_Zstat = ''. l_string = 'ALL'. endif.
      CALL METHOD l_client->request->set_header_field
        EXPORTING
          name  = 'iflowstatus'
          value = l_string.

    endif."if P_custna is INITIAL.

  endif."if P_msgid is NOT INITIAL or

  l_client->request->set_method(  if_http_request=>co_request_method_post ).
  l_client->request->set_content_type( l_content_type ).
* Chamada do Iflow
  l_client->send( ).
* Retorno do Iflow
  l_client->receive( ).
* Status do Iflow
  l_client->response->get_status( IMPORTING
                                    code   = l_http_rc
                                    reason = l_reason ).
* Leitura do response
  l_response = l_client->response->get_cdata( ).
  free: l_client.

  if l_http_rc = 200.

*   XML para tabela interna
    CALL FUNCTION 'SCMS_STRING_TO_XSTRING'
      EXPORTING
        text   = l_response
      IMPORTING
        buffer = l_xstring
      EXCEPTIONS
        failed = 1
        OTHERS = 2.

    CALL FUNCTION 'SMUM_XML_PARSE'
      EXPORTING
        xml_input = l_xstring
      TABLES
        xml_table = t_xml_table
        return    = t_return.

    free: t_messagelogs.

    do.
*     Procura a tag Properties
      READ TABLE t_xml_table WITH KEY cname = 'properties' TRANSPORTING NO FIELDS.
      if sy-subrc ne 0.
*       Todos os pacotes lidos, sair do loop.
        exit.
      else.
        data(l_indice) = sy-tabix.
        data(l_indice_limpeza) = 1.
        do.
*         Elimina registros anteriores ao properties.
          delete t_xml_table index 1.
          l_indice_limpeza = l_indice_limpeza + 1.
          if l_indice_limpeza = l_indice.
*           Chegou no 'properties'
            delete t_xml_table INDEX 1."deleta 'properties'
            exit.
          endif.
        enddo.

        clear: W_messagelogs.
        W_messagelogs-MessageGuid                 = t_xml_table[ cname = 'MessageGuid' ]-cvalue.
        W_messagelogs-CorrelationId               = t_xml_table[ cname = 'CorrelationId' ]-cvalue.
        W_messagelogs-LogStart                    = t_xml_table[ cname = 'LogStart' ]-cvalue.
        W_messagelogs-LogEnd                      = t_xml_table[ cname = 'LogEnd' ]-cvalue.
        CONCATENATE W_messagelogs-LogStart+0(4) W_messagelogs-LogStart+5(2)
                    W_messagelogs-LogStart+8(2) into W_messagelogs-data.
        CONCATENATE W_messagelogs-LogStart+11(2) W_messagelogs-LogStart+14(2)
                    W_messagelogs-LogStart+17(2) into W_messagelogs-hora.
        W_messagelogs-horagmt = W_messagelogs-hora.
        W_messagelogs-datagmt = W_messagelogs-data.
        l_fuso = p_fuso.
        l_fuso = l_fuso * -1.
        if p_dst is NOT INITIAL.
          l_fuso = l_fuso - 1.
        endif.
        CALL FUNCTION 'IGN_TIMESTAMP_PLUSMINUS'
          EXPORTING
            START_DATE      = W_messagelogs-data
            START_TIME      = W_messagelogs-hora
            FORWARD         = ''
            BACKWARD        = 'X'
            HOURS           = l_fuso
          IMPORTING
            RESULT_DATE     = W_messagelogs-data
            RESULT_TIME     = W_messagelogs-hora
          EXCEPTIONS
            PARAMETER_ERROR = 1
            OTHERS          = 2.
        W_messagelogs-IntegrationFlowName         = t_xml_table[ cname = 'IntegrationFlowName' ]-cvalue.
        W_messagelogs-Status                      = t_xml_table[ cname = 'Status' ]-cvalue.
        W_messagelogs-LogLevel                    = t_xml_table[ cname = 'LogLevel' ]-cvalue.
        W_messagelogs-CustomStatus                = t_xml_table[ cname = 'CustomStatus' ]-cvalue.
        W_messagelogs-OriginComponentName         = t_xml_table[ cname = 'OriginComponentName' ]-cvalue.
        W_messagelogs-LocalComponentName          = t_xml_table[ cname = 'LocalComponentName' ]-cvalue.
        W_messagelogs-TransactionId               = t_xml_table[ cname = 'TransactionId' ]-cvalue.
        append W_messagelogs to T_messagelogs.

      endif.
    enddo.

*   Filtro de Package
    if P_btp is NOT INITIAL.
      if P_ZIFLOW ns '*'.
        delete t_messagelogs WHERE IntegrationFlowName ne P_ZIFLOW.
      endif.
      if P_ZIFLOW cs '*'.
        delete t_messagelogs WHERE IntegrationFlowName np P_ZIFLOW.
      endif.
    endif.

  endif."if l_http_rc = 200.

ENDFORM.   "zf_message_log


