                      catch CX_XSLT_RUNTIME_ERROR into l_exception_json.
*                 Erro no XML, exibição como texto
                        message s000(oo) with text-006 DISPLAY LIKE 'W'.
                        v_editor->set_textstream( EXPORTING text = l_payload_string ).
                    endtry.

                  when 'TEXTO'.
