                  DIRECAO   eq @w_ztbbc_log_cpi->direcao and
                  TIMESTAMP eq @w_ztbbc_log_cpi->timestamp.
          if sy-subrc eq 0.

            CALL FUNCTION 'ECATT_CONV_XSTRING_TO_STRING'
              EXPORTING
                IM_XSTRING = l_payload_xstring
              IMPORTING
                EX_STRING  = l_payload_string.

            if l_payload_string ne ''.

              if P_E_COLUMN eq 'ICONE'.
