        l_payload_string3 TYPE string,
        l_xml             type ref to cl_xml_document,
        l_exception_xml   TYPE REF TO cx_xslt_runtime_error,
        l_exception_json  TYPE REF TO CX_XSLT_RUNTIME_ERROR,
        l_root            TYPE REF TO cx_root,
        l_url(200)        TYPE c VALUE 'https://corp-AMBIENTE.integrationsuite.cfapps.br10.hana.ondemand.com/shell/monitoring/Messages/%7B%22identifier%22%3A%22GUID%22%7D',
        l_pzhora1         type sy-uzeit,
        l_pzhora2         type sy-uzeit,
        l_ifloname(200)   type c,
        l_iflowauth(40)    type c.

  if p_btp is NOT INITIAL.
    if P_E_COLUMN = 'MESSAGEGUID'.
*     Abre URL no Navegador
      READ TABLE t_messagelogs INTO w_messagelogs INDEX P_ES_ROW_NO-ROW_ID.
      if sy-subrc eq 0 and w_messagelogs-Messageguid ne ''.
*         Ajusta URL
        if sy-host cs '05c' or sy-host cs '05a'.
*         Muda para parâmetros de Produção
          REPLACE 'AMBIENTE' IN l_url WITH 'prd'.
        else.
          REPLACE 'AMBIENTE' IN l_url WITH 'dev'.
        endif.
        REPLACE 'GUID' IN l_url WITH w_messagelogs-MessageGuid.

        CALL FUNCTION 'CALL_BROWSER'
          EXPORTING
            URL                    = l_url
          EXCEPTIONS
            FRONTEND_NOT_SUPPORTED = 1
            FRONTEND_ERROR         = 2
            PROG_NOT_FOUND         = 3
            NO_BATCH               = 4
            UNSPECIFIED_ERROR      = 5
            OTHERS                 = 6.
      endif.
    else.
*     Abre Text Editor
      READ TABLE t_messagelogs into w_messagelogs
                                 INDEX P_ES_ROW_NO-ROW_ID.
      IF sy-subrc = 0.
*       Busca Custom Header
        perform zf_message_customheader USING w_messagelogs-messageguid
                                        CHANGING l_payload_string.

        if l_payload_string ne ''.
*         Achou Custom Header
          l_payload_string = |Custom Header\n{ l_payload_string }\n|.
          v_editor_btp->set_textstream( EXPORTING text = l_payload_string ).
        else.
*         Não achou Custom Header
          l_payload_string = |No Custom Header\n{ l_payload_string }|.
          v_editor_btp->set_textstream( EXPORTING text = l_payload_string ).
        endif.

        l_payload_string = |{ l_payload_string }\n---------------------------------------------------\n|.

*       Busca Error Informattion
        clear: l_payload_string2.
        perform zf_message_log_errorinfo USING w_messagelogs-messageguid
                                         CHANGING l_payload_string2.
        if l_payload_string2 ne ''.
*         Achou Erro
          l_payload_string = |{ l_payload_string }Error Information\n{ l_payload_string2 }|.
          v_editor_btp->set_textstream( EXPORTING text = l_payload_string ).
        else.
*         Não achou erro
          l_payload_string = |{ l_payload_string }No error Information|.
          v_editor_btp->set_textstream( EXPORTING text = l_payload_string ).
        endif.

        l_payload_string = |{ l_payload_string }\n---------------------------------------------------\n|.

*       Busca Attachemnts

        clear: l_payload_string2.
        free: t_attachment.
        perform zf_message_log_attach USING w_messagelogs-messageguid
                                            '' "ID Anexo
                                      CHANGING l_payload_string2.
        if t_attachment[] is NOT INITIAL.
*         Achou Attachemnts
          loop at t_attachment into w_attachment.
            perform zf_message_log_attach USING w_messagelogs-messageguid
                                                w_attachment-id "ID Anexo
                                          CHANGING l_payload_string2.
            if l_payload_string2 ne ''.
              l_payload_string = |{ l_payload_string }\n Attachments: { w_attachment-name }\n|.
              l_iflowauth = l_ifloname = w_messagelogs-IntegrationFlowName.
              AUTHORITY-CHECK OBJECT 'ZO:IFLOW02'
               ID 'ACTVT' FIELD '03'
               ID 'IFLOW' FIELD l_iflowauth.
              if sy-subrc eq 0.
                l_payload_string = |{ l_payload_string }\n { l_payload_string2 }|.
              else.
                l_payload_string = |{ l_payload_string }\n No authority to see payload. Check transaction SU53.\n|.
              endif.
            else.
*             Não achou Attachemnts
              l_payload_string = |{ l_payload_string }Attachments not found|.
            endif.
            l_payload_string = |{ l_payload_string }\n---------------------------------------------------\n|.
          endloop.
          v_editor_btp->set_textstream( EXPORTING text = l_payload_string ).
        endif.

      ENDIF ."READ TABLE t_messagelogs
    endif.
  endif." if p_btp is NOT INITIAL.

  if p_sap is NOT INITIAL.

    if P_E_COLUMN eq 'ICONEBTP'.
*     Mostrar log no Integration Suite
      READ TABLE T_ZTBBC_LOG_CPI REFERENCE INTO data(w_ztbbc_log_cpi2) INDEX P_E_ROW-index.
      if sy-subrc eq 0.
        if w_ztbbc_log_cpi2->correlationid ne ''.
          SUBMIT ZCPI_LOGS WITH p_sap    = ''
                                            WITH p_btp    = 'X'
                                            WITH P_corid = w_ZTBBC_LOG_CPI2->correlationid
                                            AND RETURN.
        else.
          if w_ztbbc_log_cpi2->Messageid ne ''.
            SUBMIT ZCPI_LOGS WITH p_sap    = ''
                                              WITH p_btp    = 'X'
                                              WITH P_msgid = w_ZTBBC_LOG_CPI2->messageid
                                              AND RETURN.
          else.
            l_pzhora1 = w_ZTBBC_LOG_CPI2->hora - 5.
            l_pzhora2 = w_ZTBBC_LOG_CPI2->hora + 5.
            SUBMIT ZCPI_LOGS WITH p_sap    = ''
                                              WITH p_btp    = 'X'
                                              WITH P_ZIFLOW = w_ZTBBC_LOG_CPI2->iflow
                                              WITH p_zdata1 = w_ZTBBC_LOG_CPI2->data
                                              WITH p_zhora1 = l_pzhora1
                                              WITH p_zdata2 = w_ZTBBC_LOG_CPI2->data
                                              WITH p_zhora2 = l_pzhora2
                                              AND RETURN.
          endif."if w_ztbbc_log_cpi2->Messageid ne ''.
        endif."if w_ztbbc_log_cpi2->correlationid ne ''.
      endif."READ TABLE T_ZTBBC_LOG_CPI REFERENCE INTO data(w_ztbbc_log_cpi2) INDEX P_E_ROW-index.

    elseif P_E_COLUMN eq 'MESSAGEID'.
*   Abre URL no Navegador
      READ TABLE T_ZTBBC_LOG_CPI REFERENCE INTO data(w_ztbbc_log_cpi3) INDEX P_E_ROW-index.
      if sy-subrc eq 0 and w_ztbbc_log_cpi3->Messageid ne ''.
*         Ajusta URL
        if sy-host cs '05c' or sy-host cs '05a'.
