*&---------------------------------------------------------------------*
*&     Form zf_autorizacao
*&---------------------------------------------------------------------*
FORM zf_autorizacao .
  data: l_memory_id    type char30,
        l_iflow_import type ztbbc_log_cpi-iflow.

  SELECT bukrs
         INTO TABLE @DATA(t_t001)
         FROM t001
         WHERE bukrs in @s_bukrs.
  LOOP AT t_t001
       ASSIGNING FIELD-SYMBOL(<f_t001>).
    DATA(l_tabix) = sy-tabix.
    AUTHORITY-CHECK OBJECT 'F_BKPF_BUK'
    ID 'BUKRS' FIELD <f_t001>-bukrs
    ID 'ACTVT' FIELD '03'.
    IF sy-subrc <> 0. "Auth check failed
      DELETE t_t001 INDEX l_tabix.
    ENDIF.
  ENDLOOP.

  if t_t001[] is INITIAL.
    MESSAGE s000(oo) WITH text-005 DISPLAY LIKE 'E'.
    stop.
  else.

    if p_est is NOT INITIAL.
      if s_data[] is INITIAL.
        MESSAGE s000(oo) WITH text-008 DISPLAY LIKE 'E'.
        stop.
      endif.
    endif.

    SELECT mandt BUKRS DATA HORA IFLOW PROGRAMA DIRECAO TIMESTAMP MATNR
           LIFNR KUNNR PERNR EBELN BANFN VBELN COD_PROCESSO
           HTTP_CODE STATUS TIPO USUARIO MSG_SIZE MESSAGEID CORRELATIONID
      FROM ZTBBC_LOG_CPI
      INTO CORRESPONDING FIELDS OF TABLE t_ZTBBC_LOG_CPI
      FOR ALL ENTRIES IN t_t001
      WHERE BUKRS     eq t_t001-bukrs
        AND DATA      IN s_data
        AND HORA      IN s_hora
        AND MATNR     IN s_MATNR
        AND LIFNR     IN s_LIFNR
        AND KUNNR     IN s_KUNNR
        AND PERNR     IN s_PERNR
        AND EBELN     IN s_EBELN
        AND BANFN     IN s_BANFN
        AND VBELN     IN s_VBELN
        AND cod_processo IN s_PROCe
        AND usuario   IN s_usua
        AND PROGRAMA  IN s_prog
        AND IFLOW     IN s_iflow
        AND STATUS    IN s_stat
        AND HTTP_CODE IN s_http
        AND DIRECAO   IN s_direc.
    if t_ZTBBC_LOG_CPI[] is NOT INITIAL.
      LOOP AT t_ZTBBC_LOG_CPI ASSIGNING FIELD-SYMBOL(<f_tab>).
        if <f_tab>-tipo = 'TEXTO'.
          <f_tab>-icone = '@OC@'.
        elseif <f_tab>-TIPO = 'XML'.
          <f_tab>-icone = '@R4@'.
        elseif <f_tab>-TIPO = 'JSON'.
          <f_tab>-icone = '@0P@'.
        endif.
        <f_tab>-iconebtp = '@RJ@'." ICON_WD_WEB_PROJECT
      ENDLOOP.
    endif.
  endif.

ENDFORM.   "zf_autorizacao

*&---------------------------------------------------------------------*
*&     Form zf_saneamento_log
*&---------------------------------------------------------------------*
FORM zf_saneamento_log .
  data: t_ztbbc_parametros type TABLE of ztbbc_parametros,
        l_dias_log         TYPE i value '365',
        l_dias_log_pa      TYPE i value '180',
        l_usuario          TYPE sy-uname,
        l_erro             type REF TO CX_SY_ITAB_LINE_NOT_FOUND,
        l_erro_user        type REF TO CX_SY_ITAB_LINE_NOT_FOUND,
        l_data             type sy-datum.

* Verificar se é background
  if sy-batch is NOT INITIAL.
    CALL FUNCTION 'ZFSD_CONSTANTES1'
      EXPORTING
        I_CODE           = 'ZCPI_LOGS'
      TABLES
        ZTBBC_PARAMETROS = t_ztbbc_parametros
      EXCEPTIONS
        NOT_FOUND        = 1
        OTHERS           = 2.

    TRY.
        l_dias_log = t_ztbbc_parametros[ zparam = 'DIASLOG' ]-ZVLPAR.
      CATCH CX_SY_ITAB_LINE_NOT_FOUND INTO l_erro.
    ENDTRY.

    TRY.
        l_dias_log_pa = t_ztbbc_parametros[ zparam = 'DIASLOGPAYLOAD' ]-ZVLPAR.
      CATCH CX_SY_ITAB_LINE_NOT_FOUND INTO l_erro.
    ENDTRY.

    TRY.
        l_usuario = t_ztbbc_parametros[ zparam = 'USUARIO' ZVLPAR = sy-uname ]-ZVLPAR.
      CATCH CX_SY_ITAB_LINE_NOT_FOUND INTO l_erro_user.
    ENDTRY.

    if l_erro_user is INITIAL.
      if sy-uname = l_usuario.
        l_data = sy-datum - l_dias_log.
        delete from ztbbc_log_cpi WHERE data <= l_data.
        l_data = sy-datum - l_dias_log_pa.
        delete from ztbbc_log_cpi_pa WHERE data <= l_data.
        commit WORK AND WAIT.
      endif.
    endif.

  endif.

ENDFORM.   "zf_saneamento_log

*&---------------------------------------------------------------------*
*&     Form zf_estatisticas
*&---------------------------------------------------------------------*
FORM zf_estatisticas .
  data: w_estatistica   TYPE y_estatistica,
        l_n_bukrs(15)   TYPE p DECIMALS 0,
        l_n_iflow(15)   TYPE p DECIMALS 0,
        l_n_bytes_buk   TYPE ZTBBC_LOG_CPI-msg_size,
        l_n_bytes_ifl   TYPE ZTBBC_LOG_CPI-msg_size,
        l_n_kbytes_buk  TYPE p DECIMALS 6,
        l_n_kbytes_ifl  TYPE p DECIMALS 6,
        l_n_mbytes_buk  TYPE p DECIMALS 6,
        l_n_mbytes_ifl  TYPE p DECIMALS 6,
        l_bukrs_ant     TYPE bukrs,
        l_iflow_ant     TYPE ZTBBC_LOG_CPI-iflow,
        w_ZTBBC_LOG_CPI type y_ZTBBC_LOG_CPI.

  sort t_ZTBBC_LOG_CPI[] by bukrs iflow.
  free: t_estatistica.

  if p_estb is not INITIAL."Detalhar por interface

    loop at t_ZTBBC_LOG_CPI INTO w_ZTBBC_LOG_CPI.

      IF l_bukrs_ant IS INITIAL AND l_iflow_ant IS INITIAL.
*       Primeiro registro
        l_bukrs_ant = w_ZTBBC_LOG_CPI-bukrs.
        l_iflow_ant = w_ZTBBC_LOG_CPI-iflow.
        l_n_bukrs = 0.
        l_n_iflow = 0.
        l_n_bytes_buk = 0.
        l_n_bytes_ifl = 0.
        l_n_kbytes_buk = 0.
        l_n_kbytes_ifl = 0.
        l_n_mbytes_buk = 0.
        l_n_mbytes_ifl = 0.
      ENDIF.

*     Se mudou o BUKRS
      IF l_bukrs_ant <> w_ZTBBC_LOG_CPI-bukrs or
        l_iflow_ant <> w_ZTBBC_LOG_CPI-iflow.

        if l_bukrs_ant <> w_ZTBBC_LOG_CPI-bukrs.
*         Mudou a empresa, registra e zera contagem
          w_estatistica-qtde_iflow = 0.
          w_estatistica-bukrs       = l_bukrs_ant.
          w_estatistica-qtde_bukrs  = l_n_bukrs.
          APPEND w_estatistica TO t_estatistica.
          w_estatistica-qtde_bukrs  = 0.
          w_estatistica-iflow       = l_iflow_ant.
          w_estatistica-qtde_iflow  = l_n_iflow.
          w_estatistica-msg_size    = l_n_bytes_ifl.
          w_estatistica-msg_size_kb = l_n_kbytes_ifl.
          w_estatistica-msg_size_mb = l_n_mbytes_ifl.
          APPEND w_estatistica TO t_estatistica.
          CLEAR w_estatistica.
          l_bukrs_ant               = w_ZTBBC_LOG_CPI-bukrs.
          l_n_bukrs                 = 0.
          l_iflow_ant               = w_ZTBBC_LOG_CPI-iflow.
          l_n_iflow                 = 0.
          l_n_bytes_buk             = 0.
          l_n_bytes_ifl             = 0.
          l_n_kbytes_buk            = 0.
          L_N_KBYTES_IFL            = 0.
          L_N_MBYTES_IFL            = 0.
          l_n_mbytes_buk            = 0.

        ELSEIF l_iflow_ant <> w_ZTBBC_LOG_CPI-iflow.
*         Empresa igual, mas Iflow mudou
          w_estatistica-bukrs       = l_bukrs_ant.
          w_estatistica-iflow       = l_iflow_ant.
          w_estatistica-qtde_iflow  = l_n_iflow.
          w_estatistica-msg_size    = l_n_bytes_ifl.
          w_estatistica-msg_size_kb = l_n_kbytes_ifl.
          w_estatistica-msg_size_mb = l_n_mbytes_ifl.
          w_estatistica-qtde_bukrs = 0.
          APPEND w_estatistica TO t_estatistica.
          CLEAR w_estatistica.
          l_iflow_ant              = w_ZTBBC_LOG_CPI-iflow.
          l_n_iflow                = 0.
          l_n_bytes_ifl            = 0.
          l_n_kbytes_ifl           = 0.
          l_n_mbytes_ifl           = 0.

        ENDIF.

      ENDIF.

*     Acumula quantidades
      l_n_bukrs = l_n_bukrs + 1.
      l_n_iflow = l_n_iflow + 1.
*     Acumula tamanho das mensagens em bytes
      l_n_bytes_ifl = l_n_bytes_ifl + w_ZTBBC_LOG_CPI-msg_size.
      l_n_kbytes_ifl = l_n_kbytes_ifl + ( w_ZTBBC_LOG_CPI-msg_size / 1024 ).
      l_n_mbytes_ifl = l_n_mbytes_ifl + ( ( w_ZTBBC_LOG_CPI-msg_size / 1024 ) / 1024 ).

    endloop."loop at t_ZTBBC_LOG_CPI REFERENCE INTO data(w_ZTBBC_LOG_CPI).

*   Após o LOOP, gravar o último grupo
    if l_bukrs_ant > 0.
      w_estatistica-iflow       = ''.
      w_estatistica-qtde_iflow  = 0.
      w_estatistica-bukrs       = w_ZTBBC_LOG_CPI-bukrs.
      w_estatistica-qtde_bukrs  = l_n_bukrs.
      w_estatistica-msg_size    = l_n_bytes_buk.
      w_estatistica-msg_size_kb = l_n_kbytes_buk.
      w_estatistica-msg_size_mb = l_n_mbytes_buk.
      APPEND w_estatistica TO t_estatistica.
      w_estatistica-qtde_bukrs  = 0.
      w_estatistica-iflow       = w_ZTBBC_LOG_CPI-iflow.
      w_estatistica-qtde_iflow  = l_n_iflow.
      w_estatistica-msg_size    = l_n_bytes_ifl.
      w_estatistica-msg_size_kb = l_n_kbytes_ifl.
      w_estatistica-msg_size_mb = l_n_mbytes_ifl.
      APPEND w_estatistica TO t_estatistica.
      CLEAR w_estatistica.
    ENDIF.

  else.
*   Sem detalhar por Iflow
    loop at t_ZTBBC_LOG_CPI INTO w_ZTBBC_LOG_CPI.
      IF l_bukrs_ant IS INITIAL AND l_iflow_ant IS INITIAL.
*       Primeiro registro
        l_bukrs_ant = w_ZTBBC_LOG_CPI-bukrs.
        l_n_bukrs      = 0.
        l_n_kbytes_buk = 0.
        l_n_mbytes_buk = 0.
      ENDIF.
*     Se mudou o BUKRS
      IF l_bukrs_ant <> w_ZTBBC_LOG_CPI-bukrs or
*       Mudou a empresa, registra e zera contagem
        w_estatistica-bukrs       = w_ZTBBC_LOG_CPI-bukrs.
        w_estatistica-bukrs       = l_bukrs_ant.
        w_estatistica-qtde_bukrs  = l_n_bukrs.
        w_estatistica-msg_size    = l_n_bytes_buk.
        w_estatistica-msg_size_kb = l_n_kbytes_buk.
        w_estatistica-msg_size_mb = l_n_mbytes_buk.
        APPEND w_estatistica TO t_estatistica.
        CLEAR w_estatistica.
        l_bukrs_ant              = w_ZTBBC_LOG_CPI-bukrs.
        l_n_bukrs                = 0.
        l_n_bytes_buk            = 0.
        l_n_kbytes_buk           = 0 .
        l_n_mbytes_buk           = 0 .
      ENDIF.
*     Acumula quantidades
      l_n_bukrs = l_n_bukrs + 1.
*     Acumula tamanho das mensagens em bytes
      l_n_bytes_buk  = l_n_bytes_buk + w_ZTBBC_LOG_CPI-msg_size.
      l_n_kbytes_buk = l_n_kbytes_buk + ( w_ZTBBC_LOG_CPI-msg_size / 1024 ).
      l_n_mbytes_buk = l_n_mbytes_buk + ( ( w_ZTBBC_LOG_CPI-msg_size / 1024 ) / 1024 ).
    endloop."loop at t_ZTBBC_LOG_CPI REFERENCE INTO data(w_ZTBBC_LOG_CPI).

*   Após o LOOP, gravar o último grupo
    if l_bukrs_ant > 0.
      w_estatistica-bukrs       = w_ZTBBC_LOG_CPI-bukrs.
      w_estatistica-qtde_bukrs  = l_n_bukrs.
      w_estatistica-msg_size    = l_n_bytes_buk.
      w_estatistica-msg_size_kb = l_n_kbytes_buk.
      w_estatistica-msg_size_mb = l_n_mbytes_buk.
      APPEND w_estatistica TO t_estatistica.
    ENDIF.

  endif.

ENDFORM.   "zf_estatisticas
