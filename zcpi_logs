    EXPORTING
      name  = 'messageguid'
      value = l_string.

  l_string = p_id.
  CALL METHOD l_client->request->set_header_field
    EXPORTING
      name  = 'anexoid'
      value = l_string.

  l_client->request->set_method(  if_http_request=>co_request_method_post ).
  l_client->request->set_content_type( l_content_type ).
* Anexando Payload
  l_client->request->set_cdata( data = l_string ).
* Chamada do Iflow
  l_client->send( ).
* Retorno do Iflow
  l_client->receive( ).
* Status do Iflow
  l_client->response->get_status( IMPORTING
                                    code   = l_http_rc
                                    reason = l_reason ).
* Leitura do response
  l_response = l_client->response->get_cdata( ).
  CLEAR p_response.

  if p_id is NOT INITIAL.
*    Retorna o conteúdo dos anexos
    if l_http_rc = 200 or l_http_rc = 202 or l_http_rc = 204.
      p_response = l_response.
    endif."if l_http_rc = 200.

  else.
*   Retorna o ID dos anexo.
    free: l_client, t_attachment.

    " Encontrar índice inicial da tag <node1>
    if l_http_rc = 200.
      do.
        l_start = 0.
        FIND '<d:Id>' IN l_response MATCH OFFSET l_start.
        IF sy-subrc = 0.
          l_start = l_start + strlen('<d:Id>').
          " Encontrar índice final antes da tag </node1>
          FIND '</d:Id>' IN l_response MATCH OFFSET l_end.
          IF sy-subrc = 0 AND l_end > l_start.
            l_tam = l_end - l_start.
            l_value = l_response+l_start(l_tam).
            W_attachment-id = l_value.
*           Apagar do início da tag de abertura até o final da tag fechamento
            l_pos_end_tag = l_end + strlen('</d:Id>'). " posição depois da tag fechamento
            l_response = l_response+l_pos_end_tag.
          ENDIF.
        else.
          exit.
        ENDIF.
        l_start = 0.
        FIND '<d:MessageGuid>' IN l_response MATCH OFFSET l_start.
        IF sy-subrc = 0.
          l_start = l_start + strlen('<d:MessageGuid>').
          " Encontrar índice final antes da tag </node1>
          FIND '</d:MessageGuid>' IN l_response MATCH OFFSET l_end.
          IF sy-subrc = 0 AND l_end > l_start.
            l_tam = l_end - l_start.
            l_value = l_response+l_start(l_tam).
            W_attachment-MessageGuid = l_value.
*           Apagar do início da tag de abertura até o final da tag fechamento
            l_pos_end_tag = l_end + strlen('</d:MessageGuid>'). " posição depois da tag fechamento
            l_response = l_response+l_pos_end_tag.
          ENDIF.
        ENDIF.
        l_start = 0.
        FIND '<d:Name>' IN l_response MATCH OFFSET l_start.
        IF sy-subrc = 0.
          l_start = l_start + strlen('<d:Name>').
          " Encontrar índice final antes da tag </node1>
          FIND '</d:Name>' IN l_response MATCH OFFSET l_end.
          IF sy-subrc = 0 AND l_end > l_start.
            l_tam = l_end - l_start.
            l_value = l_response+l_start(l_tam).
            W_attachment-name = l_value.
*           Apagar do início da tag de abertura até o final da tag fechamento
            l_pos_end_tag = l_end + strlen('</d:Name>'). " posição depois da tag fechamento
            l_response = l_response+l_pos_end_tag.
          ENDIF.
        ENDIF.
        l_start = 0.
        FIND '<d:ContentType>' IN l_response MATCH OFFSET l_start.
        IF sy-subrc = 0.
          l_start = l_start + strlen('<d:ContentType>').
          " Encontrar índice final antes da tag </node1>
          FIND '</d:ContentType>' IN l_response MATCH OFFSET l_end.
          IF sy-subrc = 0 AND l_end > l_start.
            l_tam = l_end - l_start.
            l_value = l_response+l_start(l_tam).
            W_attachment-ContentType = l_value.
*           Apagar do início da tag de abertura até o final da tag fechamento
            l_pos_end_tag = l_end + strlen('</d:ContentType>'). " posição depois da tag fechamento
            l_response = l_response+l_pos_end_tag.
          ENDIF.
        ENDIF.
        append W_attachment to t_attachment.
      enddo.
    endif.

  endif." if p_id is not INITIAL.

ENDFORM.   "zf_message_log_attach


*&---------------------------------------------------------------------*
*&     Form zf_message_customheader
*&---------------------------------------------------------------------*
*&     text
*&---------------------------------------------------------------------*
*& -->  p1        text
*& <--  p2        text
*&---------------------------------------------------------------------*
FORM zf_message_customheader USING p_guid
                             CHANGING p_response.
  data: l_http_rc          type sy-subrc,
        l_reason           type String,
        l_string           type String,
        l_response         TYPE string,
        l_xstring          TYPE xstring,
        t_return           TYPE TABLE OF bapiret2,
        t_xml_table        TYPE TABLE OF smum_xmltb,
        l_client           TYPE REF TO if_http_client,
        l_dest             TYPE rfcdest,
        l_content_type     type String VALUE 'application/json',
        l_param            type ZDEGL_PARAM value 'VSADEV',
        t_ztbbc_parametros TYPE TABLE OF ztbbc_parametros,
        l_fuso             type INT4.

  if sy-host cs '05c' or sy-host cs '05a'.
*   Muda para parâmetros de Produção
    l_param = 'VSAPRD'.
  endif.

  CALL FUNCTION 'ZFSD_CONSTANTES1'
    EXPORTING
      I_CODE           = 'ZCPI_LOGS'
      I_PARAM          = l_param
    TABLES
      ZTBBC_PARAMETROS = t_ztbbc_parametros
    EXCEPTIONS
      NOT_FOUND        = 1
      OTHERS           = 2.

  IF line_exists( t_ztbbc_parametros[ zparam = l_param ] ).
    l_dest =  t_ztbbc_parametros[ zparam = l_param ]-zvlpar.
  endif.

* Relacionar SM59 configurada para ambiente BTP
  free: l_client.
  cl_http_client=>create_by_destination(
     EXPORTING destination = l_dest "SM59
     IMPORTING client      = l_client ).

* Informar no Header o nome da interface a ser chamada
  CALL METHOD l_client->request->set_header_field
    EXPORTING
      name  = 'iflowname'
      value = 'IF_VSA_MANAGEMENT_Get_MessageLogCustomHeaderValue'.

  l_string = p_guid.

  CALL METHOD l_client->request->set_header_field
    EXPORTING
      name  = 'messageguid'
      value = l_string.

  l_client->request->set_method(  if_http_request=>co_request_method_post ).
  l_client->request->set_content_type( l_content_type ).
* Chamada do Iflow
  l_client->send( ).
* Retorno do Iflow
  l_client->receive( ).
* Status do Iflow
  l_client->response->get_status( IMPORTING
                                    code   = l_http_rc
                                    reason = l_reason ).
* Leitura do response
  l_response = l_client->response->get_cdata( ).
  free: l_client, l_xstring.

* XML para tabela interna
  CALL FUNCTION 'SCMS_STRING_TO_XSTRING'
    EXPORTING
      text   = l_response
    IMPORTING
      buffer = l_xstring
    EXCEPTIONS
      failed = 1
      OTHERS = 2.

  CALL FUNCTION 'SMUM_XML_PARSE'
    EXPORTING
      xml_input = l_xstring
    TABLES
      xml_table = t_xml_table
      return    = t_return.

  free: T_customheader, l_response.

  do.
*   Procura a tag Properties
    READ TABLE t_xml_table WITH KEY cname = 'properties' TRANSPORTING NO FIELDS.
    if sy-subrc ne 0.
*     Todos os pacotes lidos, sair do loop.
      exit.
    else.
      data(l_indice) = sy-tabix.
      data(l_indice_limpeza) = 1.
      do.
*       Elimina registros anteriores ao properties.
        delete t_xml_table index 1.
        l_indice_limpeza = l_indice_limpeza + 1.
        if l_indice_limpeza = l_indice.
*         Chegou no 'properties'
          delete t_xml_table INDEX 1."deleta 'properties'
          exit.
        endif.
      enddo.
      clear: W_customheader.
      W_customheader-id         = t_xml_table[ cname = 'Id' ]-cvalue.
      W_customheader-Name       = t_xml_table[ cname = 'Name' ]-cvalue.
      W_customheader-value      = t_xml_table[ cname = 'Value' ]-cvalue.
      CONCATENATE l_response '/' W_customheader-Name '=' W_customheader-value into l_response.
      append W_customheader to T_customheader.

    endif.
  enddo.

  CLEAR p_response.
  if l_http_rc = 200 or l_http_rc = 202 or l_http_rc = 204.

    p_response = l_response.

  endif."if l_http_rc = 200.

ENDFORM.   "zf_message_customheader

